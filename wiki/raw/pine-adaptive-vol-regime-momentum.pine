//@version=6
// Title: Adaptive Vol Regime Momentum
// Kind: strategy
// Tags: Momentum, Volatility
strategy("Adaptive_Vol_Regime_Momentum", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=10, currency=currency.USD, initial_capital=10000, commission_type=strategy.commission.percent, commission_value=0.04)

// === PART 1: 입력 파라미터 ===
grpMom = "모멘텀 엔진"
lenRSI = input.int(14, "RSI 길이", minval=1, group=grpMom)
rsiMidline = input.int(50, "RSI 중심선", group=grpMom)

grpRegime = "변동성 레짐 설정"
volLen = input.int(20, "변동성 측정 길이", minval=1, group=grpRegime)
volAvgLen = input.int(100, "변동성 기준선 길이", minval=1, group=grpRegime)
regimeBoost = input.float(5.0, "고변동성 임계값 가산", minval=0.0, group=grpRegime)

grpRisk = "리스크 관리"
atrLen = input.int(14, "ATR 길이", minval=1, group=grpRisk)
slMult = input.float(2.0, "손절 ATR 배수", minval=0.1, group=grpRisk)
tpMult = input.float(3.0, "익절 ATR 배수", minval=0.1, group=grpRisk)

// === PART 2: 변동성 레짐 판별 ===
logRet = math.log(close / math.max(close[1], 0.00001))
volNow = ta.stdev(logRet, volLen)
volBaseline = ta.sma(volNow, volAvgLen)
highVolRegime = volNow > volBaseline

// 고변동성 구간에서는 진입 임계값을 높여 노이즈 필터링
longThreshold = highVolRegime ? rsiMidline + regimeBoost : rsiMidline
shortThreshold = highVolRegime ? rsiMidline - regimeBoost : rsiMidline

// === PART 3: 모멘텀 조건 ===
rsiVal = ta.rsi(close, lenRSI)
atrVal = ta.atr(atrLen)
longCondition = ta.crossover(rsiVal, longThreshold)
shortCondition = ta.crossunder(rsiVal, shortThreshold)
exitCondition = ta.cross(rsiVal, rsiMidline)

// === PART 4: 실행 엔진 ===
var float slPrice = na
var float tpPrice = na

if longCondition and strategy.position_size == 0
    strategy.entry("Long", strategy.long)
    slPrice := close - atrVal * slMult
    tpPrice := close + atrVal * tpMult

if shortCondition and strategy.position_size == 0
    strategy.entry("Short", strategy.short)
    slPrice := close + atrVal * slMult
    tpPrice := close - atrVal * tpMult

if strategy.position_size > 0
    if exitCondition or low <= slPrice or high >= tpPrice
        strategy.close("Long", comment="롱 청산")

if strategy.position_size < 0
    if exitCondition or high >= slPrice or low <= tpPrice
        strategy.close("Short", comment="숏 청산")

// === PART 5: 시각화 & 알림 ===
bgcolor(highVolRegime ? color.new(color.orange, 90) : na, title="고변동성 레짐")
plotshape(longCondition, "롱 진입", location=location.belowbar, color=color.green, style=shape.triangleup, size=size.small)
plotshape(shortCondition, "숏 진입", location=location.abovebar, color=color.red, style=shape.triangledown, size=size.small)
alertcondition(longCondition, title="롱 진입 알림", message="변동성 레짐 모멘텀 롱 신호")
alertcondition(shortCondition, title="숏 진입 알림", message="변동성 레짐 모멘텀 숏 신호")
