//@version=6
// Title: Session ORB RVOL Staged
// Kind: strategy
// Tags: Time_Based, Volume, Volatility
// Concept: US session opening range breakout with RVOL confirmation and 2-stage signals (Pre→Confirm), ATR risk
// Repaint policy: bar_close — 바 종가 확정 후 시그널 — 리페인트 최소화
strategy("Session_ORB_RVOL_Staged", overlay=true, initial_capital=10000, default_qty_type=strategy.percent_of_equity, default_qty_value=10, currency=currency.USD)

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 01 - 입력
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// [AI_START_INPUTS]
orbBars = input.int(3, "오프닝 레인지 봉 수 (예: 3×5분=15분)", minval=1, group="ORB")
volLen = input.int(20, "RVOL 기준 거래량 MA", minval=5, group="RVOL")
rvolPre = input.float(1.2, "Pre RVOL 최소", minval=0.5, step=0.1, group="RVOL")
rvolConfirm = input.float(1.5, "Confirm RVOL 최소", minval=0.5, step=0.1, group="RVOL")
sessionTz = input.string("America/New_York", "세션 타임존", group="세션")
// [AI_END_INPUTS]
// [MODULE_START_EXTRA_INPUTS]

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 02 - 필터 엔진
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

use_trend = input.bool(false, "EMA 추세 필터", group="필터", tooltip="롱만 EMA50 위에서 — 숏은 반대 로직은 staged에서 처리")

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 세션 필터
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
useSessionFilter = input.bool(true, "세션 필터 사용", group="세션", tooltip="지정한 세션 시간대에만 시그널을 허용합니다")
sessionWindow = input.session("0930-1600", "세션 구간", group="세션", tooltip="시그널을 허용할 세션 구간 (거래소 시간 기준)") // TZ: America/New_York

// ATR 리스크 관리 (모듈)
riskAtrLen = input.int(14, "SL ATR Length", group="리스크", tooltip="손절 폭 계산에 쓰는 ATR 기간")
slAtrMult = input.float(1.5, "SL ATR Multiplier", group="리스크", tooltip="손절 거리 = ATR × 이 배수")
tpRR = input.float(2.0, "TP Risk Reward", group="리스크", tooltip="익절 거리 = 손절 거리 × 이 손익비")
riskAtr = ta.atr(riskAtrLen)
// [MODULE_END_EXTRA_INPUTS]

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 02 - 필터 / 확인
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
longCondition = false
shortCondition = false
exitCondition = false
// [MODULE_START_FILTERS]
sessionOk = not useSessionFilter or not na(time(timeframe.period, sessionWindow))
_taHoist1 = ta.ema(close, 50)
trendOk = not use_trend or (close > _taHoist1)
allFiltersOk = sessionOk and trendOk
confirmOk = barstate.isconfirmed
// [MODULE_END_FILTERS]

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 02b - 코어 로직 (extra_pine — 시그널보다 먼저)
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// [MODULE_START_EXTRA_PINE]

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 사용자 확장 Pine
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// ORB 코어 — 세션 시작 후 N봉으로 레인지 구축
inSess = not na(time(timeframe.period, sessionWindow, sessionTz))
sessStart = inSess and not inSess[1]
var int barsFromOpen = 0
var float orHigh = na
var float orLow = na
if sessStart
    barsFromOpen := 0
    orHigh := high
    orLow := low
else if inSess
    barsFromOpen += 1
    if barsFromOpen <= orbBars
        orHigh := math.max(orHigh, high)
        orLow := math.min(orLow, low)
orReady = barsFromOpen > orbBars and not na(orHigh)
orMid = (orHigh + orLow) / 2
rvol = volume / math.max(ta.sma(volume, volLen), 1)
plot(orHigh, "OR High", color=color.new(color.green, 30), linewidth=2)
plot(orLow, "OR Low", color=color.new(color.red, 30), linewidth=2)
bgcolor(orReady and close > orHigh ? color.new(color.green, 92) : orReady and close < orLow ? color.new(color.red, 92) : na)
// [MODULE_END_EXTRA_PINE]

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 03 - 시그널 로직
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// [AI_START_CONDITIONS]

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 단계형 시그널 (Pre → Confirmed)
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

preLong = orReady and close < orHigh and close > orMid and rvol >= rvolPre
preShort = orReady and close > orLow and close < orMid and rvol >= rvolPre
var int lastSignalLeg = 0  // 1=long, -1=short
_taHoist2 = ta.crossover(close, orHigh)
rawLong = orReady and _taHoist2 and rvol >= rvolConfirm
_taHoist3 = ta.crossunder(close, orLow)
rawShort = orReady and _taHoist3 and rvol >= rvolConfirm
rawLong := rawLong and confirmOk
rawShort := rawShort and confirmOk
rawLong := rawLong and allFiltersOk
rawShort := rawShort and allFiltersOk
longCondition := false
shortCondition := false
if rawLong and lastSignalLeg != 1
    longCondition := true
    lastSignalLeg := 1
if rawShort and lastSignalLeg != -1
    shortCondition := true
    lastSignalLeg := -1
// [AI_END_CONDITIONS]

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 03b - 리스크
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// [MODULE_START_RISK]

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// ATR 손익 청산
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
if strategy.position_size > 0
    strategy.exit("Long SL/TP", "Long", stop=strategy.position_avg_price - riskAtr * slAtrMult, profit=strategy.position_avg_price + riskAtr * slAtrMult * tpRR)
if strategy.position_size < 0
    strategy.exit("Short SL/TP", "Short", stop=strategy.position_avg_price + riskAtr * slAtrMult, profit=strategy.position_avg_price - riskAtr * slAtrMult * tpRR)
// [MODULE_END_RISK]

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 04 - 실행 엔진
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
if longCondition and strategy.position_size == 0
    strategy.entry("Long", strategy.long)
if shortCondition and strategy.position_size == 0
    strategy.entry("Short", strategy.short)
if exitCondition and strategy.position_size != 0
    strategy.close_all()

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 05 - 시각화
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
plotshape(longCondition, title="Long", location=location.belowbar, color=color.green, style=shape.triangleup, size=size.tiny)
plotshape(shortCondition, title="Short", location=location.abovebar, color=color.red, style=shape.triangledown, size=size.tiny)
// [MODULE_START_VISUALS]

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 시각화 레이어
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
_taHoist4 = ta.crossover(close, orHigh)
plotshape(orReady and _taHoist4, title="OR Break Up", style=shape.circle, location=location.belowbar, size=size.tiny)
// [MODULE_END_VISUALS]

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 06 - 알림
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// [MODULE_START_ALERTS]

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 알림
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

alertcondition(longCondition, title="Session_ORB_RVOL_Staged Long", message="Session_ORB_RVOL_Staged LONG on {ticker} / {interval}")
alertcondition(shortCondition, title="Session_ORB_RVOL_Staged Short", message="Session_ORB_RVOL_Staged SHORT on {ticker} / {interval}")
alertcondition(exitCondition, title="Session_ORB_RVOL_Staged Exit", message="Session_ORB_RVOL_Staged EXIT on {ticker} / {interval}")
alertcondition(preLong, title="Session_ORB_RVOL_Staged Pre-Long", message="Pre-LONG signal")
alertcondition(preShort, title="Session_ORB_RVOL_Staged Pre-Short", message="Pre-SHORT signal")
if longCondition
    alert("Session_ORB_RVOL_Staged LONG | " + syminfo.ticker + " " + timeframe.period, alert.freq_once_per_bar_close)
if shortCondition
    alert("Session_ORB_RVOL_Staged SHORT | " + syminfo.ticker + " " + timeframe.period, alert.freq_once_per_bar_close)
// [MODULE_END_ALERTS]

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 07 - 대시보드
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// [MODULE_START_DASHBOARD]

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 대시보드
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
var table dash = table.new(position.top_right, 2, 3, border_width=1, force_overlay=true)
if barstate.islast
    table.cell(dash, 0, 0, "Session_ORB_RVOL_Staged", text_size=size.small)
    table.cell(dash, 1, 0, "STATUS", text_size=size.small)
    table.cell(dash, 0, 1, "Signal", text_size=size.small)
    signalTxt = longCondition ? "LONG" : shortCondition ? "SHORT" : "WAIT"
    table.cell(dash, 1, 1, signalTxt, text_size=size.small)
// [MODULE_END_DASHBOARD]
