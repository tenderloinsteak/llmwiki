//@version=6
// Title: Dynamic Adaptive Volatility Breakout
// Kind: strategy
// Tags: Volatility, Breakout
strategy("Dynamic_Adaptive_Volatility_Breakout", overlay=true, initial_capital=10000, default_qty_type=strategy.percent_of_equity, default_qty_value=1, currency=currency.USD)

// === [AI INJECTION ZONE: PARAMETERS & INDICATORS] ===
// 입력 변수
fastPeriod = input.int(20, "Fast EMA 기간")
slowPeriod = input.int(50, "Slow EMA 기간")
volLookback = input.int(14, "변동성 Lookback")
atrMultiplier = input.float(1.5, "ATR 멀티플리케이터")
riskPct = input.float(1.0, "포지션당 위험 %") / 100

// 지표
emaFast = ta.ema(close, fastPeriod)
emaSlow = ta.ema(close, slowPeriod)
sma200 = ta.sma(close, 200)
atrVal = ta.atr(volLookback)

// === [AI INJECTION ZONE: ENTRY & EXIT CONDITIONS] ===
// 진입 조건
uptrend = close > sma200
breakout = close > ta.highest(high, volLookback)
volatile = atrVal > emaFast * 0.5
longCondition = uptrend and close > emaFast and close > emaSlow and breakout and volatile

// === [FIXED SKELETON: MIDDLEWARE / SETUP] ===
timeframeFilter = input.timeframe("15", "Trading Timeframe")
useTimeframeFilter = input.bool(true, "Use Timeframe Filter")
useSessionFilter = input.bool(false, "Use Session Filter")
sessionStart = input.session("0930-1600", "Trading Session")
inTimeframe = not useTimeframeFilter or timeframe.isintraday and timeframe.multiplier <= 60
inSession = not useSessionFilter or time(timeframe.period, sessionStart)
src = close
high_ = high
low_ = low
open_ = open
volume_ = volume

// === [FIXED SKELETON: EXECUTION ENGINE] ===
var float entryPrice = na
var float stopLossPrice = na
var float takeProfitPrice = na
var int positionSize = 0
useStopLoss = true
useTakeProfit = true
maxPositionSize = input.int(1, "Max Concurrent Positions")

if inTimeframe and inSession
    if longCondition and strategy.position_size == 0
        strategy.entry("Long", strategy.long)
        entryPrice := close
        stopLossPrice := entryPrice - (math.max(atrVal, 0.00001) * atrMultiplier)
        takeProfitPrice := entryPrice + (math.max(atrVal, 0.00001) * atrMultiplier * 2)
        label.new(bar_index, entryPrice, text="Size: " + str.tostring(strategy.position_size), style=label.style_label_up, color=color.blue, textcolor=color.white, size=size.tiny)
    if strategy.position_size > 0
        if low <= stopLossPrice
            strategy.close("Long", comment="Stop Loss")
        else if high >= takeProfitPrice
            strategy.close("Long", comment="Take Profit")

// === [FIXED SKELETON: VISUALIZATION & ALERTS] ===
plot(emaFast, "Fast EMA", color=color.yellow)
plot(emaSlow, "Slow EMA", color=color.orange)
plotshape(longCondition and strategy.position_size == 0, title="Long Entry", location=location.belowbar, color=color.green, style=shape.triangleup, size=size.small)
plot(stopLossPrice, "Stop Loss", color=color.red, style=plot.style_linebr)
plot(takeProfitPrice, "Take Profit", color=color.green, style=plot.style_linebr)

alertcondition(longCondition, title="Long Entry Alert", message="Long entry signal detected")
stopHit = low <= stopLossPrice and strategy.position_size > 0
takeHit = high >= takeProfitPrice and strategy.position_size > 0
alertcondition(stopHit, title="Stop Loss Hit", message="Stop loss hit")
alertcondition(takeHit, title="Take Profit Hit", message="Take profit hit")
var float peakEquity = 0.0
peakEquity := math.max(peakEquity, strategy.equity)
equityFall = strategy.equity < peakEquity * 0.95
alertcondition(equityFall, title="Equity Fall Alert", message="Equity fell 5% from peak")
