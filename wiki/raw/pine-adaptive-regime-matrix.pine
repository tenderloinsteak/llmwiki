//@version=6
// Title: Adaptive Regime Matrix
// Kind: indicator
// Tags: Trend, Volatility, Moving_Averages
indicator("Adaptive_Regime_Matrix", shorttitle="AVRM", overlay=true, format=format.price, precision=2)

// =============================================================================
// Part 1: Inputs & Settings (입력 및 설정)
// =============================================================================
grp_ema     = "이동평균선(EMA) 설정"
emaFastLen  = input.int(9, "빠른 EMA 기간", minval=1, group=grp_ema)
emaSlowLen  = input.int(21, "느린 EMA 기간", minval=1, group=grp_ema)

grp_vol     = "변동성 및 필터 설정"
atrLen      = input.int(14, "ATR 기간", minval=1, group=grp_vol)
chopLen     = input.int(14, "횡보(Choppiness) 지표 기간", minval=1, group=grp_vol)
chopThresh  = input.float(50.0, "추세 전환 기준선", minval=0.0, maxval=100.0, group=grp_vol)

grp_vis     = "시각화 설정"
showTable   = input.bool(true, "정보 대시보드 테이블 표시", group=grp_vis)
bullColor   = input.color(color.green, "상승 신호 색상", group=grp_vis)
bearColor   = input.color(color.red, "하락 신호 색상", group=grp_vis)

// =============================================================================
// Part 2: Filter Engine & Data Sources (필터 엔진 및 데이터 소스)
// =============================================================================
// 핵심 지표 계산
emaFast = ta.ema(close, emaFastLen)
emaSlow = ta.ema(close, emaSlowLen)
atrVal  = ta.atr(atrLen)

// 횡보 지표 (Choppiness Index) 계산 및 0 나누기 방지
highestHigh = ta.highest(high, chopLen)
lowestLow   = ta.lowest(low, chopLen)
rangeHighLow = highestHigh - lowestLow
rangeSafe    = math.max(rangeHighLow, 0.00001) // 0 나누기 방지
sumAtr       = math.sum(atrVal, chopLen)
chopVal      = 100 * math.log10(sumAtr / rangeSafe) / math.log10(chopLen)

// =============================================================================
// Part 3: Custom Logic (사용자 정의 로직)
// =============================================================================
// 추세 상태 감지 (횡보 지수 기준)
isTrending = chopVal < chopThresh

// 빠른 이평선이 느린 이평선을 골든크로스(상승) / 데드크로스(하락)
goldenCross = ta.crossover(emaFast, emaSlow)
deadCross   = ta.crossunder(emaFast, emaSlow)

// 최종 매매 신호 결정 (추세 구간에서만 발생하도록 필터링)
buySignal  = isTrending and goldenCross and close > emaSlow
sellSignal = isTrending and deadCross and close < emaSlow

// =============================================================================
// Part 4: Execution & Visualization (주문 실행 및 시각화)
// =============================================================================
// 이평선 플로팅
plot(emaFast, "Fast EMA", color=color.new(color.blue, 30), linewidth=2)
plot(emaSlow, "Slow EMA", color=color.new(color.orange, 30), linewidth=2)

// 신호 발생 시 차트에 화살표 표시
plotshape(buySignal, title="매수 진입", style=shape.triangleup, location=location.belowbar, color=bullColor, size=size.small, text="BUY", textcolor=color.white)
plotshape(sellSignal, title="매도 진입", style=shape.triangledown, location=location.abovebar, color=bearColor, size=size.small, text="SELL", textcolor=color.white)

// 정보 대시보드 테이블 표시
var table infoTable = table.new(position.top_right, 2, 4, border_width=1, frame_width=1, frame_color=color.gray)
if showTable and barstate.islast
    table.cell(infoTable, 0, 0, "지표 정보", bgcolor=color.gray, text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 0, "현재 상태", bgcolor=color.gray, text_color=color.white, text_size=size.small)
    
    table.cell(infoTable, 0, 1, "시장 체제 (Choppiness)", text_size=size.small)
    table.cell(infoTable, 1, 1, isTrending ? "강한 추세 구간" : "횡보/노이즈 구간", bgcolor=isTrending ? color.new(color.green, 80) : color.new(color.orange, 80), text_size=size.small)
    
    table.cell(infoTable, 0, 2, "이평 정렬", text_size=size.small)
    table.cell(infoTable, 1, 2, emaFast > emaSlow ? "상승 정렬" : "하락 정렬", bgcolor=emaFast > emaSlow ? color.new(color.green, 80) : color.new(color.red, 80), text_size=size.small)
    
    table.cell(infoTable, 0, 3, "횡보 지수 (CI)", text_size=size.small)
    table.cell(infoTable, 1, 3, str.tostring(chopVal, "#.##"), text_size=size.small)

// =============================================================================
// Part 5: Alerts & Risk Management (알림 및 리스크 관리)
// =============================================================================
alertcondition(buySignal, title="매수 얼럿", message="Premium AV_Regime: 상승 추세 진입 (BUY)")
alertcondition(sellSignal, title="매도 얼럿", message="Premium AV_Regime: 하락 추세 진입 (SELL)")
