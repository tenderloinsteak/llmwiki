//@version=6
// Title: Full Platform SKU-08
// Kind: indicator
// Tags: Price_Action, FVG, Liquidity, Volume, Time_Based, Dashboard
// Concept: SKU-08 Full Platform — all live modules flagship
// Tier: platform
// Repaint policy: bar_close
indicator("Full_Platform_SKU08", shorttitle="FP08", overlay=true, max_polylines_count=100, max_labels_count=500, max_boxes_count=500, max_lines_count=500)

// [PLATFORM_START_INPUTS]

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 00 - 플랫폼 마스터 설정
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

grpPlatform = "Full_Platform_SKU08 Platform"
swingLen = input.int(5, "스윙 피벗 길이", minval=2, group=grpPlatform, display=display.none, tooltip="주요 시장 구조를 잡는 스윙 포인트 길이 — 크게 하면 굵직한 구조만 표시됩니다")
internalLen = input.int(3, "내부 스윙 길이", minval=2, group=grpPlatform, display=display.none, tooltip="단기(내부) 구조 탐지 길이 — 스윙 피벗 길이보다 작게 설정하세요")
maxBoxCap = input.int(200, "최대 박스 수", minval=20, group=grpPlatform, display=display.none, tooltip="차트에 유지할 박스 최대 개수 — 초과 시 오래된 것부터 자동 삭제됩니다")
maxLineCap = input.int(200, "최대 라인 수", minval=20, group=grpPlatform, display=display.none, tooltip="차트에 유지할 라인 최대 개수 — 초과 시 오래된 것부터 자동 삭제됩니다")
confirmBars = input.bool(true, "바 종가 확정 후 시그널", group=grpPlatform, display=display.none, tooltip="봉 마감 확정 후에만 시그널을 표시해 리페인트를 방지합니다")
// Registry modules (173): alerts, bar_close_confirm, block_last_opposite_candle, block_order_bull_bear, block_breaker, block_mitigation, block_ob_alert, block_ob_mtf, block_ob_score, block_propulsion, block_rejection, block_volume_imbalance_ob
//   + dashboard, exec_atr_sl_tp, exec_backtest_hints, exec_bracket_orders, exec_exit_signal, exec_position_sizing, exec_same_bar_rules, exec_strategy_entry_engine, exec_tp_ladder, exec_trade_box_fsm, exec_trailing_stop, filters
tzSess = input.string("America/New_York", "타임존", group=grpPlatform, display=display.none, tooltip="세션·킬존 계산 기준 타임존")
// Optional cross-module defaults when feature modules absent
useAlertHub = input.bool(true, "알림 허브", group=grpPlatform, display=display.none, tooltip="진입·구조·영역 터치 알림을 통합 관리합니다")
useOrderBlocks = input.bool(true, "오더 블록", group=grpPlatform, display=display.none, tooltip="기관 매집·분산 추정 구간(오더 블록)을 표시합니다")
useFvg = input.bool(true, "Fair Value Gap", group=grpPlatform, display=display.none, tooltip="가격 불균형(FVG) 영역을 박스로 표시합니다")
useDrawMgr = input.bool(true, "드로잉 매니저", group=grpPlatform, display=display.none, tooltip="박스·라인 등 드로잉 객체의 수명주기를 자동 관리합니다")
useLiquidity = input.bool(true, "동일 고저 유동성", group=grpPlatform, display=display.none, tooltip="동일 고점(EQH)·동일 저점(EQL) 유동성 라인을 표시합니다")
useSessions = input.bool(true, "세션 프로필", group=grpPlatform, display=display.none, tooltip="아시아·런던·뉴욕 세션 구간과 고저를 표시합니다")
useMarketStructure = input.bool(true, "시장 구조 (BOS/CHoCH)", group=grpPlatform, display=display.none, tooltip="구조 돌파(BOS)와 추세 전환(CHoCH)을 자동 마킹합니다")
useMtfDash = input.bool(true, "MTF 대시보드", group=grpPlatform, display=display.none, tooltip="다중 시간대 추세 편향을 우측 패널에 요약합니다")
useTheme = input.bool(true, "테마/스타일", group=grpPlatform, display=display.none, tooltip="MantisAlgo 시그니처 팔레트(teal/orange)를 적용합니다")
grpVisual = "차트 표시 (겹침 방지)"
showSessBg = input.bool(false, "세션·킬존 배경색", group=grpVisual, tooltip="아시아·런던·뉴욕 세션과 킬존 구간을 배경 음영으로 표시합니다")
showVolBg = input.bool(false, "볼륨·VWAP 배경색", group=grpVisual, tooltip="볼륨 급증·VWAP 이격 구간을 배경 음영으로 표시합니다")
showSigBg = input.bool(false, "시그널 합류 배경색", group=grpVisual, tooltip="다중 조건이 합류한 구간을 배경 음영으로 강조합니다")
showOrbMarkers = input.bool(true, "ORB 돌파 마커", group=grpVisual, tooltip="오프닝 레인지(개장 변동폭) 돌파 시 삼각형 마커를 표시합니다")
showPlatformDash = input.bool(true, "플랫폼 상태 패널 (우하단)", group=grpVisual, tooltip="구조·모멘텀·세션 상태를 요약한 실시간 패널을 표시합니다")
grpFlag = "플래그십"
showAll = input.bool(true, "전체 모듈", group=grpFlag, tooltip="모든 모듈 표시/숨김 마스터 토글")
// [PLATFORM_END_INPUTS]
// [AI_START_INPUTS]

// [AI_END_INPUTS]

// [PLATFORM_START_TYPES]

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 01 - UDT 타입
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

type SwingPoint
    int barIdx
    float price
    int dir

type FvgZone
    box bx
    float top
    float bot
    int dir
    bool active

type OrderBlock
    box bx
    float top
    float bot
    int dir
    bool mitigated

type LiquidityLevel
    line ln
    float price
    int dir
// [PLATFORM_END_TYPES]

// [PLATFORM_START_HELPERS]

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 19 - 헬퍼 라이브러리
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

f_isBullBar() =>
    close > open

f_isBearBar() =>
    close < open

f_bodyRatio() =>
    rangeBar = math.max(high - low, syminfo.mintick)
    math.abs(close - open) / rangeBar

f_upperWick() =>
    math.max(high - math.max(open, close), 0.0)

f_lowerWick() =>
    math.max(math.min(open, close) - low, 0.0)

f_atrPct(len) =>
    ta.atr(len) / close * 100

f_nearLevel(price, level, tol) =>
    not na(level) and math.abs(price - level) <= tol

f_safeEma(src, len) =>
    ta.ema(src, math.max(len, 1))

f_safeRsi(src, len) =>
    ta.rsi(src, math.max(len, 2))

f_volRatio(len) =>
    volume / math.max(ta.sma(volume, len), 1)

f_trendStrength() =>
    ema20 = ta.ema(close, 20)
    ema50 = ta.ema(close, 50)
    ema20 > ema50 ? 1 : ema20 < ema50 ? -1 : 0

f_hasBullStack() =>
    volR = f_volRatio(20)
    f_isBullBar() and f_bodyRatio() > 0.5 and volR > 1.2

f_hasBearStack() =>
    volR = f_volRatio(20)
    f_isBearBar() and f_bodyRatio() > 0.5 and volR > 1.2
// [PLATFORM_END_HELPERS]

// [PLATFORM_START_DRAWING]

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// infra_bar_close_gate
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

barCloseGate = barstate.isconfirmed
signalsOk = not confirmBars or barCloseGate


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 02 - 드로잉 매니저 (배열 lifecycle)
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

var array<box> boxPool = array.new_box()
var array<line> linePool = array.new_line()
var array<label> labelPool = array.new_label()

f_trim_boxes() =>
    while array.size(boxPool) > maxBoxCap
        bx = array.shift(boxPool)
        if not na(bx)
            box.delete(bx)

f_trim_lines() =>
    while array.size(linePool) > maxLineCap
        ln = array.shift(linePool)
        if not na(ln)
            line.delete(ln)

f_trim_labels() =>
    while array.size(labelPool) > 100
        lb = array.shift(labelPool)
        if not na(lb)
            label.delete(lb)

f_push_box(bx) =>
    if useDrawMgr and not na(bx)
        array.push(boxPool, bx)
        f_trim_boxes()

f_push_line(ln) =>
    if useDrawMgr and not na(ln)
        array.push(linePool, ln)
        f_trim_lines()

f_push_label(lb) =>
    if useDrawMgr and not na(lb)
        array.push(labelPool, lb)
        f_trim_labels()

if useDrawMgr and barstate.islastconfirmedhistory
    f_trim_boxes()
    f_trim_lines()
    f_trim_labels()


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// infra_polyline_manager
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

var array<polyline> managedPolylines = array.new_polyline()
f_push_polyline(pl) =>
    if array.size(managedPolylines) >= 50
        polyline.delete(array.shift(managedPolylines))
    array.push(managedPolylines, pl)

// Repaint policy: bar_close — 바 종가 확정 후 시그널 — 리페인트 최소화


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// infra_resource_limits
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

// max_* attrs declared in indicator() header


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// infra_runtime_tf_guard
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

if timeframe.in_seconds() < 60
    runtime.error("TF guard: 1m+ only")


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// infra_section_headers
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

// Korean section headers injected per module sec()


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// infra_version_stamp
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

// Registry module version stamp — SKU assembly marker
// [PLATFORM_END_DRAWING]

// [PLATFORM_START_THEME]

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// ui_visual_director — 표시 계층
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

displayProfile = input.string("Standard", "표시 프로필", options=["Compact", "Standard", "Full"], group=grpVisual, tooltip="Compact: 핵심 구조만 / Standard: 권장 기본값 / Full: 모든 보조 마커까지 표시")
showTier1 = true
showTier2 = displayProfile != "Compact"
showTier3 = displayProfile == "Full"
compactMode = displayProfile == "Compact"


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 10 - 테마
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

grpTheme = "테마/색상"
bullColorIn = input.color(color.teal, "상승", group=grpTheme, inline="thm1", tooltip="상승(불) 요소 기본 색 — 구조·FVG·시그널에 공통 적용됩니다")
bearColorIn = input.color(color.orange, "하락", group=grpTheme, inline="thm1", tooltip="하락(베어) 요소 기본 색 — 구조·FVG·시그널에 공통 적용됩니다")
neutralColorIn = input.color(color.gray, "중립", group=grpTheme, inline="thm1", tooltip="중립·보조 요소 색 — 라벨 및 비활성 상태에 적용됩니다")
zoneTransp = input.int(85, "영역 투명도", minval=50, maxval=98, group=grpTheme, tooltip="FVG·오더블록 등 영역 채우기 투명도 — 높을수록 옅어집니다")
bullColor = useTheme ? bullColorIn : color.green
bearColor = useTheme ? bearColorIn : color.red
neutralColor = useTheme ? color.new(neutralColorIn, 40) : color.gray
fvgBullBg = useTheme ? color.new(bullColorIn, zoneTransp) : color.new(color.green, 88)
fvgBearBg = useTheme ? color.new(bearColorIn, zoneTransp) : color.new(color.red, 88)
// [PLATFORM_END_THEME]

// [PLATFORM_START_STRUCTURE]

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// struct_fib_auto — 자동 피보나치
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

fibzShow = input.bool(true, "자동 피보나치", group=grpVisual, tooltip="최근 확정 스윙 고점·저점 기준 피보나치 되돌림 레벨을 자동으로 그립니다")
fibzPh = ta.pivothigh(high, swingLen, swingLen)
fibzPl = ta.pivotlow(low, swingLen, swingLen)
var float fibzHi = na
var float fibzLo = na
if not na(fibzPh)
    fibzHi := fibzPh
if not na(fibzPl)
    fibzLo := fibzPl
var array<line> fibzLines = array.new<line>()
var array<label> fibzLabels = array.new<label>()
if fibzShow and barstate.islast and not na(fibzHi) and not na(fibzLo) and fibzHi > fibzLo
    while array.size(fibzLines) > 0
        line.delete(array.pop(fibzLines))
    while array.size(fibzLabels) > 0
        label.delete(array.pop(fibzLabels))
    fibzRatios = array.from(0.0, 0.382, 0.5, 0.618, 0.786, 1.0)
    fibzX1 = bar_index - swingLen * 4
    for fibzI = 0 to array.size(fibzRatios) - 1
        fibzR = array.get(fibzRatios, fibzI)
        fibzLevel = fibzHi - (fibzHi - fibzLo) * fibzR
        fibzCol = fibzR == 0.618 ? color.new(color.teal, 20) : color.new(color.gray, 45)
        array.push(fibzLines, line.new(fibzX1, fibzLevel, bar_index, fibzLevel, color=fibzCol, width=fibzR == 0.618 ? 2 : 1, style=line.style_dashed))
        array.push(fibzLabels, label.new(bar_index, fibzLevel, str.tostring(fibzR, "#.###"), style=label.style_label_left, color=color.new(color.black, 100), textcolor=fibzCol, size=size.tiny))


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// struct_history_sweep
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

histSweep = high > ta.highest(high[1], 20) and close < high
plotshape(showTier3 and (histSweep), title="Hist Sweep", style=shape.xcross, location=location.abovebar, color=color.red, size=size.tiny)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 03 - 시장 구조 엔진 (BOS / CHoCH)
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

var int msTrend = 0
var float lastSwingHigh = na
var float lastSwingLow = na
var float prevSwingHigh = na
var float prevSwingLow = na

ph = ta.pivothigh(high, swingLen, swingLen)
pl = ta.pivotlow(low, swingLen, swingLen)

if useMarketStructure
    if not na(ph)
        prevSwingHigh := lastSwingHigh
        lastSwingHigh := ph
    if not na(pl)
        prevSwingLow := lastSwingLow
        lastSwingLow := pl

_crossBosUp = ta.crossover(close, lastSwingHigh)
_crossBosDn = ta.crossunder(close, lastSwingLow)
bosUp = useMarketStructure and not na(lastSwingHigh) and _crossBosUp
bosDn = useMarketStructure and not na(lastSwingLow) and _crossBosDn
chochUp = useMarketStructure and msTrend <= 0 and bosUp
chochDn = useMarketStructure and msTrend >= 0 and bosDn

if useMarketStructure
    if bosUp
        msTrend := 1
    if bosDn
        msTrend := -1

internalPh = ta.pivothigh(high, internalLen, internalLen)
internalPl = ta.pivotlow(low, internalLen, internalLen)
var float intHigh = na
var float intLow = na
if useMarketStructure
    if not na(internalPh)
        intHigh := internalPh
    if not na(internalPl)
        intLow := internalPl

_crossIntBosUp = ta.crossover(close, intHigh)
_crossIntBosDn = ta.crossunder(close, intLow)
intBosUp = useMarketStructure and not na(intHigh) and _crossIntBosUp
intBosDn = useMarketStructure and not na(intLow) and _crossIntBosDn

structMarkBull = bosUp or chochUp
structMarkBear = bosDn or chochDn
_showBosUp = bosUp and not chochUp
_showBosDn = bosDn and not chochDn

_chochPlusVolMa = ta.sma(volume, 20)
chochPlusUp = chochUp and barstate.isconfirmed and volume > _chochPlusVolMa
chochPlusDn = chochDn and barstate.isconfirmed and volume > _chochPlusVolMa
_showChochUp = chochUp and not chochPlusUp
_showChochDn = chochDn and not chochPlusDn

plotshape(useMarketStructure and showTier1 and _showBosUp and (not confirmBars or barstate.isconfirmed),
     title="BOS Up", style=shape.labelup, location=location.belowbar,
     color=color.new(color.green, 0), text="BOS", size=size.tiny)
plotshape(useMarketStructure and showTier1 and _showBosDn and (not confirmBars or barstate.isconfirmed),
     title="BOS Dn", style=shape.labeldown, location=location.abovebar,
     color=color.new(color.red, 0), text="BOS", size=size.tiny)
plotshape(useMarketStructure and showTier1 and _showChochUp and (not confirmBars or barstate.isconfirmed),
     title="CHoCH Up", style=shape.diamond, location=location.belowbar,
     color=color.new(color.teal, 0), text="CH+", size=size.tiny)
plotshape(useMarketStructure and showTier1 and _showChochDn and (not confirmBars or barstate.isconfirmed),
     title="CHoCH Dn", style=shape.diamond, location=location.abovebar,
     color=color.new(color.orange, 0), text="CH-", size=size.tiny)

msBias = msTrend > 0 ? "BULL" : msTrend < 0 ? "BEAR" : "NEUT"

f_structureBias() =>
    msTrend

f_midRange() =>
    float result = not na(lastSwingHigh) and not na(lastSwingLow) ? (lastSwingHigh + lastSwingLow) / 2 : na
    result

f_inDiscount() =>
    mid = f_midRange()
    not na(mid) and close < mid

f_inPremium() =>
    mid = f_midRange()
    not na(mid) and close > mid

f_compositeBias() =>
    f_trendStrength() + f_structureBias()


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// struct_bos_validation
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

bosValLen = input.int(10, "BOS Val Len", group=grpPlatform, tooltip="BOS 유효성 검증 룩백 길이")
bosValHigh = ta.highest(high, bosValLen)
bosValLow = ta.lowest(low, bosValLen)
bosValidBull = ta.crossover(close, bosValHigh[1])
bosValidBear = ta.crossunder(close, bosValLow[1])
plotshape(showTier3 and (bosValidBull), "BOS Val Bull", style=shape.labelup, location=location.belowbar, color=color.green, size=size.tiny)
plotshape(showTier3 and (bosValidBear), "BOS Val Bear", style=shape.labeldown, location=location.abovebar, color=color.red, size=size.tiny)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// struct_breaker_level
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

breakerLvl = ta.highest(high, swingLen * 2)
plot(breakerLvl, "Breaker", color=color.orange, style=plot.style_linebr)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// struct_choch_plus — CHoCH+ confirmed
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

plotshape(showTier1 and (chochPlusUp), title="CHoCH+", style=shape.labelup, location=location.belowbar,
     color=color.new(color.lime, 0), text="CH++", size=size.small)
plotshape(showTier1 and (chochPlusDn), title="CHoCH+ Bear", style=shape.labeldown, location=location.abovebar,
     color=color.new(color.fuchsia, 0), text="CH--", size=size.small)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// struct_dealing_range
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

dealHigh = ta.highest(high, 50)
dealLow = ta.lowest(low, 50)
dealMid = (dealHigh + dealLow) / 2
plot(dealMid, "Dealing Mid", color=color.blue)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// struct_eqh_eql
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

eqTol = ta.atr(14) * 0.05
eqHighStruct = not na(ph) and not na(prevSwingHigh) and math.abs(ph - prevSwingHigh) <= eqTol
eqLowStruct = not na(pl) and not na(prevSwingLow) and math.abs(pl - prevSwingLow) <= eqTol
plotshape(showTier3 and (eqHighStruct), title="EQH", style=shape.xcross, location=location.abovebar, color=color.red, size=size.tiny)
plotshape(showTier3 and (eqLowStruct), title="EQL", style=shape.xcross, location=location.belowbar, color=color.green, size=size.tiny)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// struct_hierarchy_st_it_lt
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

// ST / IT / LT 3-tier structure
stPh = ta.pivothigh(high, 3, 3)
stPl = ta.pivotlow(low, 3, 3)
itPh = ta.pivothigh(high, 5, 5)
itPl = ta.pivotlow(low, 5, 5)
ltPh = ta.pivothigh(high, 10, 10)
ltPl = ta.pivotlow(low, 10, 10)

var int stTrend = 0
var int itTrend = 0
var int ltTrend = 0
if not na(stPh) and close < stPh
    stTrend := -1
if not na(stPl) and close > stPl
    stTrend := 1
_crossItPh = ta.crossover(close, itPh)
_crossItPl = ta.crossunder(close, itPl)
if not na(itPh) and _crossItPh
    itTrend := 1
if not na(itPl) and _crossItPl
    itTrend := -1
if not na(ltPh)
    ltTrend := close > ltPh ? 1 : close < ltPl ? -1 : ltTrend

hierarchyBull = stTrend >= 0 and itTrend >= 0 and ltTrend >= 0
hierarchyBear = stTrend <= 0 and itTrend <= 0 and ltTrend <= 0
bgcolor(showSigBg and hierarchyBull ? color.new(color.teal, 97) : hierarchyBear ? color.new(color.orange, 97) : na)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// struct_internal_bos
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

// internal BOS — included in struct_market_bos_choch (internalPh/intBosUp)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// struct_it_ltf_sync
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

ltfBos = request.security(syminfo.tickerid, "5", bosUp, barmerge.gaps_off, barmerge.lookahead_off)
htfBos = bosUp
syncBull = ltfBos and htfBos


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// struct_mss
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

mssLen = input.int(5, "MSS Len", group=grpPlatform, tooltip="시장 구조 전환(MSS) 탐지 길이")
mssPh = ta.pivothigh(high, mssLen, mssLen)
mssPl = ta.pivotlow(low, mssLen, mssLen)
var float mssLastHigh = na
var float mssLastLow = na
if not na(mssPh)
    mssLastHigh := mssPh
if not na(mssPl)
    mssLastLow := mssPl
mssBull = not na(mssLastLow) and close > mssLastHigh
mssBear = not na(mssLastHigh) and close < mssLastLow


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// struct_premium_discount — PD Array
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

pdMid = f_midRange()
pdPremium = not na(pdMid) and close > pdMid
pdDiscount = not na(pdMid) and close < pdMid
_pdAtr = ta.atr(14)
pdEquilibrium = not na(pdMid) and math.abs(close - pdMid) <= _pdAtr * 0.1

plot(pdMid, "Equilibrium", color=color.new(color.gray, 40), linewidth=1, style=plot.style_circles)
bgcolor(showSigBg and pdPremium ? color.new(color.red, 96) : showSigBg and pdDiscount ? color.new(color.green, 96) : na)
plotshape(showTier3 and (pdEquilibrium), title="EQ", style=shape.cross, location=location.absolute, color=color.gray, size=size.tiny)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// struct_bias_dashboard
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

var table structDash = table.new(position.middle_right, 2, 4, border_width=1)
if barstate.islast
    table.cell(structDash, 0, 0, "STRUCT", text_size=size.tiny)
    table.cell(structDash, 1, 0, msBias, text_size=size.tiny)
    table.cell(structDash, 0, 1, "ST")
    table.cell(structDash, 1, 1, hierarchyBull ? "BULL" : hierarchyBear ? "BEAR" : "—", text_size=size.tiny)
    table.cell(structDash, 0, 2, "PD")
    table.cell(structDash, 1, 2, pdPremium ? "PREM" : pdDiscount ? "DISC" : "EQ", text_size=size.tiny)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// struct_swing_pivot_engine
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

swPh = ta.pivothigh(high, internalLen, internalLen)
swPl = ta.pivotlow(low, internalLen, internalLen)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// struct_auto_tf_swings
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

autoPh = ta.pivothigh(high, swingLen, swingLen)
autoPl = ta.pivotlow(low, swingLen, swingLen)
plotshape(showTier3 and (autoPh), title="Auto PH", style=shape.triangledown, location=location.abovebar, color=color.red, size=size.tiny)
plotshape(showTier3 and (autoPl), title="Auto PL", style=shape.triangleup, location=location.belowbar, color=color.green, size=size.tiny)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// struct_method_udt
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

// UDT method slot — struct state via msTrend/msBias
structState = msTrend == 1 ? "BULL" : msTrend == -1 ? "BEAR" : "RANGE"


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// struct_trend_state_machine
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

var int trendFsm = 0
if bosUp
    trendFsm := 1
if bosDn
    trendFsm := -1
bgcolor(showSigBg and trendFsm == 1 ? color.new(color.green, 97) : trendFsm == -1 ? color.new(color.red, 97) : na)
// [PLATFORM_END_STRUCTURE]

// [PLATFORM_START_FVG]

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// imb_activity_asymmetry
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

asymLen = input.int(14, "Asym Len", group=grpPlatform, tooltip="상승/하락 비대칭 모멘텀 계산 기간")
upVol = math.sum(close > open ? volume : 0, asymLen)
dnVol = math.sum(close < open ? volume : 0, asymLen)
asymRatio = upVol / math.max(dnVol, 1)
plot(asymRatio, "Asym", color=color.orange, display=display.pane)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 04 - Fair Value Gap (FVG)
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

bullFvg = low > high[2] and close[1] > open[1]
bearFvg = high < low[2] and close[1] < open[1]
fvgTop = bullFvg ? low : bearFvg ? low[2] : na
fvgBot = bullFvg ? high[2] : bearFvg ? high : na
fvgDir = bullFvg ? 1 : bearFvg ? -1 : 0

var array<box> fvgBoxes = array.new_box()

if useFvg and fvgDir != 0 and (not confirmBars or barstate.isconfirmed)
    bx = box.new(bar_index - 2, fvgTop, bar_index + 8, fvgBot,
         border_color=fvgDir > 0 ? color.new(color.green, 60) : color.new(color.red, 60),
         bgcolor=fvgDir > 0 ? color.new(color.green, 88) : color.new(color.red, 88))
    array.push(fvgBoxes, bx)
    f_push_box(bx)
    while array.size(fvgBoxes) > 40
        old = array.shift(fvgBoxes)
        if not na(old)
            box.delete(old)

fvgMitigated = useFvg and fvgDir != 0 and (
     (fvgDir > 0 and low <= fvgBot) or (fvgDir < 0 and high >= fvgTop))
plotshape(useFvg and bullFvg and showTier2 and not structMarkBull, title="Bull FVG", style=shape.square,
     location=location.belowbar, color=color.new(color.green, 30), size=size.tiny)
plotshape(useFvg and bearFvg and showTier2 and not structMarkBear, title="Bear FVG", style=shape.square,
     location=location.abovebar, color=color.new(color.red, 30), size=size.tiny)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// imb_bpr — Balanced Price Range
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

bprTop = math.max(fvgTop, fvgBot)
bprBot = math.min(fvgTop, fvgBot)
bprActive = bullFvg or bearFvg
var box bprBox = na
if bprActive and barstate.isconfirmed
    if not na(bprBox)
        box.delete(bprBox)
    bprBox := box.new(bar_index - 2, bprTop, bar_index + 10, bprBot,
         bgcolor=color.new(color.yellow, 88), border_color=color.new(color.yellow, 50))
    f_push_box(bprBox)
inBpr = not na(bprBox) and close >= bprBot and close <= bprTop


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// imb_fvg_alert
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

alertcondition(bullFvg, title="FVG Bull Alert", message="Bull FVG formed")
alertcondition(bearFvg, title="FVG Bear Alert", message="Bear FVG formed")
alertcondition(fvgMitigated, title="FVG Mitigated", message="FVG mitigated")


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// imb_fvg_filter
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

fvgFilterMin = input.float(0.1, "FVG Min ATR", group=grpPlatform, tooltip="FVG 최소 크기 필터 (ATR 배수) — 작은 갭 제거")
fvgAtr = ta.atr(14)
fvgBullOk = bullFvg and (fvgTop - fvgBot) >= fvgAtr * fvgFilterMin
fvgBearOk = bearFvg and (fvgTop - fvgBot) >= fvgAtr * fvgFilterMin


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// imb_gap_fill_rate
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

gapFill = bullFvg and close < fvgBot
gapFillRate = ta.cum(gapFill ? 1 : 0) / math.max(ta.cum(bullFvg ? 1 : 0), 1)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// imb_ifvg — Inverse FVG
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

ifvgBull = bearFvg[1] and bullFvg
ifvgBear = bullFvg[1] and bearFvg
plotshape(showTier3 and (ifvgBull), title="IFVG Bull", style=shape.square, location=location.belowbar, color=color.teal, size=size.tiny)
plotshape(showTier3 and (ifvgBear), title="IFVG Bear", style=shape.square, location=location.abovebar, color=color.orange, size=size.tiny)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// imb_mitigation_lifecycle
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

mitCount = ta.cum(fvgMitigated ? 1 : 0)
plot(mitCount, "FVG Mit Count", color=color.gray, display=display.pane)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// imb_opening_gap
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

_gapAtr = ta.atr(14)
openGap = session.isfirstbar_regular and math.abs(open - close[1]) > _gapAtr * 0.5
plotshape(showTier3 and (openGap), title="Open Gap", style=shape.diamond, location=location.abovebar, color=color.yellow, size=size.tiny)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// imb_partial_fill
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

partFill = bullFvg and low <= fvgBot and close > fvgBot
plotshape(showTier3 and (partFill), title="Partial Fill", style=shape.xcross, location=location.belowbar, color=color.lime, size=size.tiny)
// [PLATFORM_END_FVG]

// [PLATFORM_START_MITIGATION]

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 13 - FVG/OB 미티게이션 추적
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

var array<float> fvgTops = array.new_float()
var array<float> fvgBots = array.new_float()
var array<int> fvgDirs = array.new_int()

if useFvg and fvgDir != 0
    array.push(fvgTops, fvgTop)
    array.push(fvgBots, fvgBot)
    array.push(fvgDirs, fvgDir)
    while array.size(fvgTops) > 50
        array.shift(fvgTops)
        array.shift(fvgBots)
        array.shift(fvgDirs)

mitigatedCount = 0
if array.size(fvgTops) > 0
    for i = 0 to array.size(fvgTops) - 1
        t = array.get(fvgTops, i)
        b = array.get(fvgBots, i)
        d = array.get(fvgDirs, i)
        hit = d > 0 ? low <= b : high >= t
        if hit
            mitigatedCount += 1

plot(mitigatedCount, "Mitigated FVG Count", color=color.new(color.gray, 50), display=display.none)
// [PLATFORM_END_MITIGATION]

// [PLATFORM_START_OB]

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// block_last_opposite_candle
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

locBull = close > open and close[1] < open[1]
locBear = close < open and close[1] > open[1]
plotshape(showTier3 and (locBull), title="LOC Bull", style=shape.circle, location=location.belowbar, color=color.teal, size=size.tiny)
plotshape(showTier3 and (locBear), title="LOC Bear", style=shape.circle, location=location.abovebar, color=color.orange, size=size.tiny)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 05 - 오더 블록 (OB)
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

_obAtr = ta.atr(14)
impulseUp = close > open and (close - open) > _obAtr * 0.8 and close > close[1]
impulseDn = close < open and (open - close) > _obAtr * 0.8 and close < close[1]

obBullTop = impulseUp ? high[1] : na
obBullBot = impulseUp ? low[1] : na
obBearTop = impulseDn ? high[1] : na
obBearBot = impulseDn ? low[1] : na

var array<box> obBoxes = array.new_box()

if useOrderBlocks and impulseUp and (not confirmBars or barstate.isconfirmed)
    ob = box.new(bar_index - 1, obBullTop, bar_index + 12, obBullBot,
         border_color=color.new(color.teal, 40), bgcolor=color.new(color.teal, 85))
    array.push(obBoxes, ob)
    f_push_box(ob)

if useOrderBlocks and impulseDn and (not confirmBars or barstate.isconfirmed)
    ob = box.new(bar_index - 1, obBearTop, bar_index + 12, obBearBot,
         border_color=color.new(color.orange, 40), bgcolor=color.new(color.orange, 85))
    array.push(obBoxes, ob)
    f_push_box(ob)

while array.size(obBoxes) > 30
    oldOb = array.shift(obBoxes)
    if not na(oldOb)
        box.delete(oldOb)

obMitigatedBull = useOrderBlocks and not na(obBullBot) and low < obBullBot
obMitigatedBear = useOrderBlocks and not na(obBearBot) and high > obBearTop


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// block_breaker
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

breakerBull = impulseUp[1] and close < obBullBot
breakerBear = impulseDn[1] and close > obBearTop
var array<box> breakerBoxes = array.new_box()
if breakerBull and barstate.isconfirmed
    bx = box.new(bar_index, high, bar_index + 8, low, bgcolor=color.new(color.blue, 85), border_color=color.blue)
    array.push(breakerBoxes, bx)
    f_push_box(bx)
if breakerBear and barstate.isconfirmed
    bx = box.new(bar_index, high, bar_index + 8, low, bgcolor=color.new(color.purple, 85), border_color=color.purple)
    array.push(breakerBoxes, bx)
    f_push_box(bx)
while array.size(breakerBoxes) > 25
    box.delete(array.shift(breakerBoxes))


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// block_mitigation
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

obMitigatedBullSignal = obMitigatedBull and barstate.isconfirmed
obMitigatedBearSignal = obMitigatedBear and barstate.isconfirmed
plotshape(showTier3 and (obMitigatedBullSignal), title="OB Mitigated Bull", style=shape.circle, location=location.belowbar, color=color.teal, size=size.tiny)
plotshape(showTier3 and (obMitigatedBearSignal), title="OB Mitigated Bear", style=shape.circle, location=location.abovebar, color=color.orange, size=size.tiny)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// block_ob_alert
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

alertcondition(impulseUp, title="OB Bull", message="Order block bull formed")
alertcondition(impulseDn, title="OB Bear", message="Order block bear formed")


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// block_ob_mtf
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

obMtf = request.security(syminfo.tickerid, "60", impulseUp, barmerge.gaps_off, barmerge.lookahead_off)
plotshape(showTier3 and (obMtf), title="OB MTF", style=shape.square, location=location.belowbar, color=color.blue, size=size.tiny)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// block_ob_score
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

obScore = impulseUp ? 2.0 : impulseDn ? -2.0 : 0.0
plot(obScore, "OB Score", color=color.purple, display=display.pane)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// block_propulsion
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

_propVolMa = ta.sma(volume, 20)
propBull = impulseUp and volume > _propVolMa * 1.5
propBear = impulseDn and volume > _propVolMa * 1.5


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// block_rejection
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

rejBull = low < obBullBot and close > obBullBot
rejBear = high > obBearTop and close < obBearTop


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// block_volume_imbalance_ob
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

_volImbMa = ta.sma(volume, 20)
volImbOb = volume > _volImbMa * 2 and (impulseUp or impulseDn)
bgcolor(showVolBg and volImbOb ? color.new(color.yellow, 95) : na)
// [PLATFORM_END_OB]

// [PLATFORM_START_SESSION]

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 07 - 세션 프로필
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

asiaSess = input.session("2000-0000", "아시아", group=grpPlatform, display=display.none, tooltip="아시아 세션 구간 (거래소 시간 기준)")
londonSess = input.session("0300-0800", "런던", group=grpPlatform, display=display.none, tooltip="런던 세션 구간 (거래소 시간 기준)")
nySess = input.session("0930-1600", "뉴욕", group=grpPlatform, display=display.none, tooltip="뉴욕 세션 구간 (거래소 시간 기준)")
inAsia = useSessions and not na(time(timeframe.period, asiaSess, tzSess))
inLondon = useSessions and not na(time(timeframe.period, londonSess, tzSess))
inNy = useSessions and not na(time(timeframe.period, nySess, tzSess))

sessionName = inNy ? "NY" : inLondon ? "LDN" : inAsia ? "ASIA" : "OFF"

var float asiaHigh = na
var float asiaLow = na
var float ldnHigh = na
var float ldnLow = na
asiaStart = inAsia and not inAsia[1]
ldnStart = inLondon and not inLondon[1]
if useSessions
    if asiaStart
        asiaHigh := high
        asiaLow := low
    else if inAsia
        asiaHigh := math.max(asiaHigh, high)
        asiaLow := math.min(asiaLow, low)
    if ldnStart
        ldnHigh := high
        ldnLow := low
    else if inLondon
        ldnHigh := math.max(ldnHigh, high)
        ldnLow := math.min(ldnLow, low)

bgcolor(useSessions and showSessBg and inAsia ? color.new(color.yellow, 95) : na)
bgcolor(useSessions and showSessBg and inLondon ? color.new(color.blue, 96) : na)
bgcolor(useSessions and showSessBg and inNy ? color.new(color.purple, 96) : na)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// sess_breakout_shape
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

breakoutShapeLen = input.int(10, "Breakout Shape Len", group=grpPlatform, tooltip="돌파 형태 판정 룩백 길이")
sessRangeHigh = ta.highest(high, breakoutShapeLen)
sessRangeLow = ta.lowest(low, breakoutShapeLen)
_crossSessUp = ta.crossover(close, sessRangeHigh)
_crossSessDn = ta.crossunder(close, sessRangeLow)
sessShapeBreakUp = inNy and _crossSessUp
sessShapeBreakDn = inNy and _crossSessDn
plot(sessRangeHigh, "Sess Range High", color=color.new(color.green, 50))
plot(sessRangeLow, "Sess Range Low", color=color.new(color.red, 50))
plotshape(showOrbMarkers and not compactMode and sessShapeBreakUp, title="Sess Shape Up", style=shape.triangleup, location=location.belowbar, color=color.green, size=size.tiny)
plotshape(showOrbMarkers and not compactMode and sessShapeBreakDn, title="Sess Shape Dn", style=shape.triangledown, location=location.abovebar, color=color.red, size=size.tiny)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// sess_compact_variant
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

compactSess = input.session("0930-1130", "Compact AM", group=grpPlatform, tooltip="간결 모드에서 강조할 오전 세션 구간")
inCompact = not na(time(timeframe.period, compactSess, tzSess))
bgcolor(showSessBg and inCompact ? color.new(color.teal, 94) : na)
_compactHi12 = ta.highest(high, 12)
compactHigh = inCompact ? _compactHi12 : na
_compactLo12 = ta.lowest(low, 12)
compactLow = inCompact ? _compactLo12 : na
plot(inCompact ? compactHigh : na, "Compact High", color=color.green)
plot(inCompact ? compactLow : na, "Compact Low", color=color.red)
_crossCompactUp = ta.crossover(close, compactHigh)
_crossCompactDn = ta.crossunder(close, compactLow)
compactBreakUp = inCompact and _crossCompactUp
compactBreakDn = inCompact and _crossCompactDn
plotshape(showOrbMarkers and not compactMode and compactBreakUp, title="Compact Up", style=shape.triangleup, location=location.belowbar, color=color.lime, size=size.tiny)
plotshape(showOrbMarkers and not compactMode and compactBreakDn, title="Compact Dn", style=shape.triangledown, location=location.abovebar, color=color.red, size=size.tiny)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// sess_killzone
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

kzLondon = input.session("0200-0500", "London KZ", group=grpPlatform, tooltip="런던 킬존 구간 (거래소 시간)")
kzNy = input.session("0830-1100", "NY KZ", group=grpPlatform, tooltip="뉴욕 킬존 구간 (거래소 시간)")
inKzLondon = not na(time(timeframe.period, kzLondon, tzSess))
inKzNy = not na(time(timeframe.period, kzNy, tzSess))
inKillzone = inKzLondon or inKzNy
bgcolor(showSessBg and inKzLondon ? color.new(color.blue, 93) : na)
bgcolor(showSessBg and inKzNy ? color.new(color.purple, 93) : na)
plotchar(showTier3 and (inKillzone), title="Killzone", char="K", location=location.top, color=color.yellow, size=size.tiny)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// sess_orb
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

orbBarsSess = input.int(3, "ORB 봉 수", minval=1, group=grpPlatform, tooltip="오프닝 레인지(ORB) 구성 봉 수")
inNyOrb = inNy
nyStart = inNyOrb and not inNyOrb[1]
var int orbBar = 0
var float orbH = na
var float orbL = na
if nyStart
    orbBar := 0
    orbH := high
    orbL := low
else if inNyOrb
    orbBar += 1
    if orbBar <= orbBarsSess
        orbH := math.max(orbH, high)
        orbL := math.min(orbL, low)
orbReady = orbBar > orbBarsSess
plot(orbReady ? orbH : na, "ORB High", color=color.green, linewidth=2)
plot(orbReady ? orbL : na, "ORB Low", color=color.red, linewidth=2)
_crossOrbUp = ta.crossover(close, orbH)
_crossOrbDn = ta.crossunder(close, orbL)
orbBreakUp = orbReady and _crossOrbUp
orbBreakDn = orbReady and _crossOrbDn
orbMid = orbReady ? (orbH + orbL) / 2.0 : na
orbRange = orbReady ? orbH - orbL : na
orbExtUp = orbReady ? orbH + orbRange * 0.5 : na
orbExtDn = orbReady ? orbL - orbRange * 0.5 : na
plot(orbMid, "ORB Mid", color=color.new(color.gray, 40), style=plot.style_circles)
plot(orbExtUp, "ORB Ext Up", color=color.new(color.green, 60))
plot(orbExtDn, "ORB Ext Dn", color=color.new(color.red, 60))


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// sess_initial_balance
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

ibBars = input.int(2, "IB 봉 수 (1시간≈12 on 5m)", minval=1, group=grpPlatform, tooltip="이니셜 밸런스 구성 봉 수")
var float ibH = na
var float ibL = na
if nyStart
    ibH := high
    ibL := low
else if inNy and orbBar <= ibBars
    ibH := math.max(ibH, high)
    ibL := math.min(ibL, low)
plot(orbBar > ibBars ? ibH : na, "IB High", color=color.new(color.blue, 30))
plot(orbBar > ibBars ? ibL : na, "IB Low", color=color.new(color.blue, 30))


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// sess_power_hour
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

powerHour = input.session("1500-1600", "Power Hour", group=grpPlatform, tooltip="파워아워 세션 구간 (거래소 시간)")
inPower = not na(time(timeframe.period, powerHour, tzSess))
bgcolor(showSessBg and inPower ? color.new(color.fuchsia, 94) : na)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// sess_statistics
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

var int orbBreaks = 0
var int orbFakes = 0
var float sessVol = 0.0
if orbBreakUp or orbBreakDn
    orbBreaks += 1
if orbBreakUp[1] and close < orbMid
    orbFakes += 1
if orbBreakDn[1] and close > orbMid
    orbFakes += 1
if inNy
    sessVol += volume
plot(orbBreaks, "ORB Break Count", display=display.none)
var table sessStats = table.new(position.middle_left, 2, 4, border_width=1)
if barstate.islast
    table.cell(sessStats, 0, 0, "SESSION", text_size=size.tiny)
    table.cell(sessStats, 1, 0, sessionName, text_size=size.tiny)
    table.cell(sessStats, 0, 1, "ORB Brk", text_size=size.tiny)
    table.cell(sessStats, 1, 1, str.tostring(orbBreaks), text_size=size.tiny)
    table.cell(sessStats, 0, 2, "Fake", text_size=size.tiny)
    table.cell(sessStats, 1, 2, str.tostring(orbFakes), text_size=size.tiny)
    table.cell(sessStats, 0, 3, "Vol", text_size=size.tiny)
    table.cell(sessStats, 1, 3, str.tostring(sessVol, "#"), text_size=size.tiny)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// sess_timezone_inputs
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

// tzSess from sess_profiles; extra TZ display
var table tzDash = table.new(position.bottom_center, 1, 1, border_width=1)
if barstate.islast
    table.cell(tzDash, 0, 0, "TZ: " + tzSess, text_size=size.tiny)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// sess_vwap_reset
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

// Session VWAP reset on NY open — complements vol_vwap_session
nyOpen = inNy and not inNy[1]
var float nyVwapNum = 0.0
var float nyVwapDen = 0.0
if nyOpen
    nyVwapNum := 0.0
    nyVwapDen := 0.0
if inNy
    nyVwapNum += hlc3 * volume
    nyVwapDen += volume
nyVwap = nyVwapDen > 0 ? nyVwapNum / nyVwapDen : na
plot(inNy ? nyVwap : na, "NY VWAP", color=color.aqua, linewidth=2)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// sess_orb_rvol — ORB + RVOL 확인
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

orbRvolMin = input.float(1.5, "ORB RVOL 최소", minval=0.5, step=0.1, group=grpPlatform, tooltip="ORB 돌파 인정 최소 상대볼륨 배수")
orbRvolLen = input.int(20, "ORB RVOL MA", minval=5, group=grpPlatform, tooltip="ORB 상대볼륨 기준 이동평균 기간")
_orbRvolMa = ta.sma(volume, orbRvolLen)
orbRvol = volume / math.max(_orbRvolMa, 1)
orbRvolOk = orbRvol >= orbRvolMin
orbConfirmUp = orbBreakUp and orbRvolOk and barstate.isconfirmed
orbConfirmDn = orbBreakDn and orbRvolOk and barstate.isconfirmed
plotshape(showOrbMarkers and orbConfirmUp, title="ORB RVOL Up", style=shape.triangleup, location=location.belowbar, color=color.lime, size=size.normal)
plotshape(showOrbMarkers and orbConfirmDn, title="ORB RVOL Dn", style=shape.triangledown, location=location.abovebar, color=color.red, size=size.normal)
var table orbDash = table.new(position.top_center, 2, 3, border_width=1)
if barstate.islast
    table.cell(orbDash, 0, 0, "ORB", text_size=size.tiny)
    table.cell(orbDash, 1, 0, orbReady ? "READY" : "BUILD", text_size=size.tiny)
    table.cell(orbDash, 0, 1, "RVOL", text_size=size.tiny)
    table.cell(orbDash, 1, 1, str.tostring(orbRvol, "#.##"), text_size=size.tiny)
    table.cell(orbDash, 0, 2, "Range", text_size=size.tiny)
    table.cell(orbDash, 1, 2, orbReady ? str.tostring(orbH - orbL, "#.##") : "—", text_size=size.tiny)
// [PLATFORM_END_SESSION]

// [PLATFORM_START_VOLUME]

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 16 - 볼륨 불균형 / IVG
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

volMa = ta.sma(volume, 20)
volSpike = volume > volMa * 2.0
body = math.abs(close - open)
rangeBar = high - low
imbalanceUp = volSpike and close > open and body > rangeBar * 0.6
imbalanceDn = volSpike and close < open and body > rangeBar * 0.6

var array<box> ivgBoxes = array.new_box()
if imbalanceUp and barstate.isconfirmed
    ivg = box.new(bar_index, high, bar_index + 6, low, bgcolor=color.new(color.teal, 90), border_width=0)
    array.push(ivgBoxes, ivg)
    f_push_box(ivg)
if imbalanceDn and barstate.isconfirmed
    ivg = box.new(bar_index, high, bar_index + 6, low, bgcolor=color.new(color.orange, 90), border_width=0)
    array.push(ivgBoxes, ivg)
    f_push_box(ivg)

while array.size(ivgBoxes) > 35
    oldI = array.shift(ivgBoxes)
    if not na(oldI)
        box.delete(oldI)

plotshape(imbalanceUp and showTier2 and not structMarkBull, title="IVG Up", style=shape.diamond, location=location.belowbar, color=color.teal, size=size.tiny)
plotshape(imbalanceDn and showTier2 and not structMarkBear, title="IVG Dn", style=shape.diamond, location=location.abovebar, color=color.orange, size=size.tiny)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// vol_cvd_proxy
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

deltaBar = close >= open ? volume : -volume
var float cvd = 0.0
cvd += deltaBar
cvdMa = ta.sma(cvd, 20)
cvdBull = cvd > cvdMa
cvdBear = cvd < cvdMa
plot(cvd, "CVD Proxy", color=color.new(color.aqua, 30), display=display.pane)
plot(cvdMa, "CVD MA", color=color.orange, display=display.pane)
bgcolor(showVolBg and cvdBull ? color.new(color.teal, 97) : showVolBg and cvdBear ? color.new(color.red, 97) : na)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// vol_delta_proxy
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

buyVol = close > open ? volume : 0
sellVol = close < open ? volume : 0
deltaRatio = buyVol / math.max(buyVol + sellVol, 1)
deltaBull = deltaRatio > 0.6
deltaBear = deltaRatio < 0.4
plot(deltaRatio, "Delta Ratio", color=color.purple, display=display.pane)
hline(0.6, "Bull Delta", color=color.green)
hline(0.4, "Bear Delta", color=color.red)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// vol_footprint_lite
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

fpRows = input.int(12, "Footprint Rows", minval=4, maxval=24, group=grpPlatform, tooltip="풋프린트 가격 구간(행) 수")
fpLookback = input.int(20, "Footprint Lookback", minval=5, group=grpPlatform, tooltip="풋프린트 분석 룩백 봉 수")
fpTop = ta.highest(high, fpLookback)
fpBot = ta.lowest(low, fpLookback)
fpStep = math.max((fpTop - fpBot) / fpRows, syminfo.mintick)

var array<float> fpBuy = array.new_float(fpRows, 0.0)
var array<float> fpSell = array.new_float(fpRows, 0.0)

if barstate.islast
    for i = 0 to fpRows - 1
        array.set(fpBuy, i, 0.0)
        array.set(fpSell, i, 0.0)
    for j = 0 to math.min(fpLookback - 1, bar_index)
        px = close[j]
        if px >= fpBot and px <= fpTop
            idx = int(math.floor((px - fpBot) / fpStep))
            idx := math.min(idx, fpRows - 1)
            if close[j] >= open[j]
                array.set(fpBuy, idx, array.get(fpBuy, idx) + volume[j])
            else
                array.set(fpSell, idx, array.get(fpSell, idx) + volume[j])
    maxFp = 0.0
    for i = 0 to fpRows - 1
        maxFp := math.max(maxFp, array.get(fpBuy, i) + array.get(fpSell, i))
    var array<box> fpBoxes = array.new_box()
    while array.size(fpBoxes) > 0
        box.delete(array.shift(fpBoxes))
    for i = 0 to fpRows - 1
        buyV = array.get(fpBuy, i)
        sellV = array.get(fpSell, i)
        tot = buyV + sellV
        if tot <= 0
            continue
        y0 = fpBot + i * fpStep
        y1 = y0 + fpStep
        buyW = int(10 * buyV / math.max(maxFp, 1))
        sellW = int(10 * sellV / math.max(maxFp, 1))
        if buyV > sellV
            bx = box.new(bar_index - fpLookback, y1, bar_index - fpLookback + buyW, y0,
                 bgcolor=color.new(color.teal, 80), border_color=color.teal)
            array.push(fpBoxes, bx)
            f_push_box(bx)
        else if sellV > buyV
            bx = box.new(bar_index - fpLookback, y1, bar_index - fpLookback + sellW, y0,
                 bgcolor=color.new(color.red, 80), border_color=color.red)
            array.push(fpBoxes, bx)
            f_push_box(bx)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// vol_imbalance_bar
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

imbBarRatio = input.float(2.0, "Imbalance Ratio", minval=1.0, step=0.1, group=grpPlatform, tooltip="임밸런스 바 판정 비율 — 클수록 엄격")
buyBar = close > open ? volume : 0
sellBar = close < open ? volume : 0
imbBullBar = buyBar > sellBar * imbBarRatio and buyBar > 0
imbBearBar = sellBar > buyBar * imbBarRatio and sellBar > 0
plotshape(showTier3 and showVolBg and imbBullBar and (not structMarkBull), title="Vol Imb Bull", style=shape.square, location=location.belowbar, color=color.teal, size=size.tiny)
plotshape(showTier3 and showVolBg and imbBearBar and (not structMarkBear), title="Vol Imb Bear", style=shape.square, location=location.abovebar, color=color.orange, size=size.tiny)
bgcolor(showVolBg and imbBullBar ? color.new(color.green, 95) : showVolBg and imbBearBar ? color.new(color.red, 95) : na)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// vol_obv_divergence — OBV 다이버전스
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

obvdLen = input.int(5, "OBV 다이버전스 피벗", minval=2, group=grpPlatform, tooltip="OBV 다이버전스 탐지용 피벗 길이 — 작을수록 민감")
// 이론: 가격 신저점 + OBV 고저점 상승 = 매집 흔적 (거래량이 가격을 선행)
obvdVal = ta.obv
obvdPl = ta.pivotlow(low, obvdLen, obvdLen)
obvdPh = ta.pivothigh(high, obvdLen, obvdLen)
obvdPriceLo = ta.valuewhen(not na(obvdPl), low[obvdLen], 0)
obvdPriceLoPrev = ta.valuewhen(not na(obvdPl), low[obvdLen], 1)
obvdObvLo = ta.valuewhen(not na(obvdPl), obvdVal[obvdLen], 0)
obvdObvLoPrev = ta.valuewhen(not na(obvdPl), obvdVal[obvdLen], 1)
obvdPriceHi = ta.valuewhen(not na(obvdPh), high[obvdLen], 0)
obvdPriceHiPrev = ta.valuewhen(not na(obvdPh), high[obvdLen], 1)
obvdObvHi = ta.valuewhen(not na(obvdPh), obvdVal[obvdLen], 0)
obvdObvHiPrev = ta.valuewhen(not na(obvdPh), obvdVal[obvdLen], 1)
obvdBullDiv = not na(obvdPl) and obvdPriceLo < obvdPriceLoPrev and obvdObvLo > obvdObvLoPrev
obvdBearDiv = not na(obvdPh) and obvdPriceHi > obvdPriceHiPrev and obvdObvHi < obvdObvHiPrev
plotshape(showTier2 and obvdBullDiv, "OBV 강세 다이버전스", shape.diamond, location.belowbar, color.new(color.teal, 15), size=size.tiny, offset=-5)
plotshape(showTier2 and obvdBearDiv, "OBV 약세 다이버전스", shape.diamond, location.abovebar, color.new(color.orange, 15), size=size.tiny, offset=-5)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// vol_poc_vah_val
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

vpLen = input.int(50, "VP Lookback", minval=10, group=grpPlatform, tooltip="볼륨 프로파일 계산 룩백 봉 수")
vpHigh = ta.highest(high, vpLen)
vpLow = ta.lowest(low, vpLen)
vpMid = (vpHigh + vpLow) / 2.0
vah = vpMid + (vpHigh - vpMid) * 0.7
val = vpMid - (vpMid - vpLow) * 0.7
poc = ta.vwap(hlc3)
plot(vah, "VAH", color=color.new(color.red, 40), style=plot.style_circles)
plot(val, "VAL", color=color.new(color.green, 40), style=plot.style_circles)
plot(poc, "POC", color=color.new(color.yellow, 20), linewidth=2)
inValueArea = close <= vah and close >= val
bgcolor(showVolBg and inValueArea ? color.new(color.blue, 97) : na)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// vol_profile_render
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

vpRenderRows = input.int(24, "Profile Rows", minval=12, group=grpPlatform, tooltip="프로파일 가격 구간(행) 수")
vpRenderLook = input.int(50, "Profile Lookback", group=grpPlatform, tooltip="프로파일 렌더링 룩백 봉 수")
vpRTop = ta.highest(high, vpRenderLook)
vpRBot = ta.lowest(low, vpRenderLook)
vpRStep = math.max((vpRTop - vpRBot) / vpRenderRows, syminfo.mintick)
var array<float> vpRenderVol = array.new_float(vpRenderRows, 0.0)
var array<box> vpRenderBoxes = array.new_box()
if barstate.islast
    for i = 0 to vpRenderRows - 1
        array.set(vpRenderVol, i, 0.0)
    for j = 0 to math.min(vpRenderLook - 1, bar_index)
        px = hlc3[j]
        if px >= vpRBot and px <= vpRTop
            idx = int(math.floor((px - vpRBot) / vpRStep))
            idx := math.min(idx, vpRenderRows - 1)
            array.set(vpRenderVol, idx, array.get(vpRenderVol, idx) + volume[j])
    maxVR = 0.0
    for i = 0 to vpRenderRows - 1
        maxVR := math.max(maxVR, array.get(vpRenderVol, i))
    while array.size(vpRenderBoxes) > 0
        box.delete(array.shift(vpRenderBoxes))
    for i = 0 to vpRenderRows - 1
        v = array.get(vpRenderVol, i)
        if v <= 0
            continue
        w = int(30 * v / math.max(maxVR, 1))
        y0 = vpRBot + i * vpRStep
        y1 = y0 + vpRStep
        bx = box.new(bar_index - vpRenderLook, y1, bar_index - vpRenderLook + w, y0,
             bgcolor=color.new(color.blue, 85), border_color=color.blue)
        array.push(vpRenderBoxes, bx)
        f_push_box(bx)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// vol_rvol
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

rvolLen = input.int(20, "RVOL MA", group=grpPlatform, tooltip="상대볼륨 기준 이동평균 기간")
_rvolMa = ta.sma(volume, rvolLen)
rvolVal = volume / math.max(_rvolMa, 1)
rvolHigh = rvolVal >= 1.5
plot(rvolVal, "RVOL", color=color.new(color.blue, 30))
hline(1.5, "RVOL 1.5", color=color.gray)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// vol_climax
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

climaxLen = input.int(20, "Climax MA", group=grpPlatform, tooltip="클라이맥스 볼륨 판정용 이동평균 기간")
climaxMult = input.float(2.5, "Climax Mult", group=grpPlatform, tooltip="평균 볼륨 대비 클라이맥스 판정 배수")
_climaxVolMa = ta.sma(volume, climaxLen)
climaxVol = volume > _climaxVolMa * climaxMult
climaxBull = climaxVol and close > open
climaxBear = climaxVol and close < open
plotshape(showVolBg and not compactMode and climaxBull, title="Vol Climax Bull", style=shape.arrowup, location=location.belowbar, color=color.teal, size=size.small)
plotshape(showVolBg and not compactMode and climaxBear, title="Vol Climax Bear", style=shape.arrowdown, location=location.abovebar, color=color.red, size=size.small)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// vol_sma_filter
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

volSmaLen = input.int(20, "Vol SMA", group=grpPlatform, tooltip="볼륨 이동평균 기간 — 급증 판정 기준")
_volSma = ta.sma(volume, volSmaLen)
volSmaOk = volume > _volSma
plotshape(showTier3 and (volSmaOk), title="Vol OK", style=shape.cross, location=location.bottom, color=color.gray, size=size.tiny)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// vol_vp_fixed
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

vpFixedRows = input.int(16, "VP Rows", minval=8, group=grpPlatform, tooltip="볼륨 프로파일 가격 구간(행) 수")
vpFixedLook = input.int(30, "VP Lookback", group=grpPlatform, tooltip="볼륨 프로파일 계산 룩백 봉 수")
vpFTop = ta.highest(high, vpFixedLook)
vpFBot = ta.lowest(low, vpFixedLook)
vpFStep = math.max((vpFTop - vpFBot) / vpFixedRows, syminfo.mintick)
var array<float> vpFixedVol = array.new_float(vpFixedRows, 0.0)
var float pocFixed = na
if barstate.islast
    for i = 0 to vpFixedRows - 1
        array.set(vpFixedVol, i, 0.0)
    for j = 0 to math.min(vpFixedLook - 1, bar_index)
        px = hlc3[j]
        if px >= vpFBot and px <= vpFTop
            idx = int(math.floor((px - vpFBot) / vpFStep))
            idx := math.min(idx, vpFixedRows - 1)
            array.set(vpFixedVol, idx, array.get(vpFixedVol, idx) + volume[j])
    maxV = 0.0
    pocI = 0
    for i = 0 to vpFixedRows - 1
        v = array.get(vpFixedVol, i)
        if v > maxV
            maxV := v
            pocI := i
    pocFixed := vpFBot + pocI * vpFStep
plot(pocFixed, "VP Fixed POC", color=color.yellow, linewidth=2)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// vol_vp_session
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

vpRows = input.int(20, "VP Rows", minval=8, maxval=40, group=grpPlatform, tooltip="볼륨 프로파일 가격 구간(행) 수")
vpLookback = input.int(40, "VP Lookback", minval=10, group=grpPlatform, tooltip="볼륨 프로파일 계산 룩백 봉 수")
vpTop = ta.highest(high, vpLookback)
vpBot = ta.lowest(low, vpLookback)
vpStep = math.max((vpTop - vpBot) / vpRows, syminfo.mintick)

var array<float> vpVol = array.new_float(vpRows, 0.0)
var array<box> vpBoxes = array.new_box()

if barstate.islast
    for i = 0 to vpRows - 1
        array.set(vpVol, i, 0.0)
    for j = 0 to math.min(vpLookback - 1, bar_index)
        px = hlc3[j]
        if px >= vpBot and px <= vpTop
            idx = int(math.floor((px - vpBot) / vpStep))
            idx := math.min(idx, vpRows - 1)
            array.set(vpVol, idx, array.get(vpVol, idx) + volume[j])
    maxVol = 0.0
    pocIdx = 0
    for i = 0 to vpRows - 1
        v = array.get(vpVol, i)
        if v > maxVol
            maxVol := v
            pocIdx := i
    pocPrice = vpBot + pocIdx * vpStep
    while array.size(vpBoxes) > 0
        box.delete(array.shift(vpBoxes))
    for i = 0 to vpRows - 1
        v = array.get(vpVol, i)
        if v <= 0
            continue
        barW = int(20 * v / math.max(maxVol, 1))
        y0 = vpBot + i * vpStep
        y1 = y0 + vpStep
        bx = box.new(bar_index - vpLookback, y1, bar_index - vpLookback + barW, y0,
             bgcolor=color.new(color.blue, 85), border_color=color.new(color.blue, 60))
        array.push(vpBoxes, bx)
        f_push_box(bx)
    var line pocLine = na
    if not na(pocLine)
        line.delete(pocLine)
    pocLine := line.new(bar_index - vpLookback, pocPrice, bar_index, pocPrice,
         color=color.yellow, width=2, style=line.style_dashed)
    f_push_line(pocLine)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// vol_vwap_bands
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

vwapBandLen = input.int(20, "VWAP Band Len", group=grpPlatform, tooltip="VWAP 밴드 표준편차 계산 기간")
vwapBandMult = input.float(2.0, "Band Mult", group=grpPlatform, tooltip="VWAP 밴드 폭 배수")
vwapBand = ta.vwap(hlc3)
vwapDev = ta.stdev(close, vwapBandLen) * vwapBandMult
vwapUpper = vwapBand + vwapDev
vwapLower = vwapBand - vwapDev
plot(vwapBand, "VWAP Band", color=color.orange)
plot(vwapUpper, "VWAP Upper", color=color.red)
plot(vwapLower, "VWAP Lower", color=color.green)
bgcolor(showVolBg and close > vwapUpper ? color.new(color.red, 95) : close < vwapLower ? color.new(color.green, 95) : na)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// vol_vwap_session
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

vwapSess = input.session("0930-1600", "VWAP 세션", group=grpPlatform, tooltip="VWAP 리셋 기준 세션")
inVwapSess = not na(time(timeframe.period, vwapSess, tzSess))
var float sessVwapNum = 0.0
var float sessVwapDen = 0.0
if inVwapSess and not inVwapSess[1]
    sessVwapNum := 0.0
    sessVwapDen := 0.0
if inVwapSess
    sessVwapNum += hlc3 * volume
    sessVwapDen += volume
sessVwap = sessVwapDen > 0 ? sessVwapNum / sessVwapDen : na
plot(inVwapSess ? sessVwap : na, "Session VWAP", color=color.fuchsia, linewidth=2)
aboveVwap = inVwapSess and close > sessVwap
belowVwap = inVwapSess and close < sessVwap
bgcolor(showVolBg and aboveVwap ? color.new(color.green, 97) : showVolBg and belowVwap ? color.new(color.red, 97) : na)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// vol_flow_dashboard
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

var table flowDash = table.new(position.bottom_left, 2, 5, border_width=1)
if barstate.islast
    table.cell(flowDash, 0, 0, "FLOW", text_size=size.tiny, bgcolor=color.new(color.gray, 80))
    table.cell(flowDash, 1, 0, "VALUE", text_size=size.tiny, bgcolor=color.new(color.gray, 80))
    table.cell(flowDash, 0, 1, "RVOL", text_size=size.tiny)
    table.cell(flowDash, 1, 1, str.tostring(rvolVal, "#.##"), text_size=size.tiny)
    table.cell(flowDash, 0, 2, "CVD", text_size=size.tiny)
    table.cell(flowDash, 1, 2, str.tostring(cvd, "#"), text_size=size.tiny)
    table.cell(flowDash, 0, 3, "Delta", text_size=size.tiny)
    table.cell(flowDash, 1, 3, str.tostring(deltaRatio, "#.##"), text_size=size.tiny)
    table.cell(flowDash, 0, 4, "VWAP", text_size=size.tiny)
    table.cell(flowDash, 1, 4, close > sessVwap ? "ABOVE" : "BELOW", text_size=size.tiny)
// [PLATFORM_END_VOLUME]

// [PLATFORM_START_LIQUIDITY]

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// liq_chart_pattern
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

liqCpHigh = ta.highest(high, 20)
liqCpLow = ta.lowest(low, 20)
liqCpMid = (liqCpHigh + liqCpLow) / 2
plot(liqCpMid, "Liq CP Mid", color=color.gray)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 06 - 유동성 (EQH / EQL)
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

eqhTol = ta.atr(14) * 0.05
eqlTol = ta.atr(14) * 0.05
eqHigh = useLiquidity and not na(ph) and not na(prevSwingHigh) and math.abs(ph - prevSwingHigh) <= eqhTol
eqLow = useLiquidity and not na(pl) and not na(prevSwingLow) and math.abs(pl - prevSwingLow) <= eqlTol

var array<line> liqLines = array.new_line()

if useLiquidity and eqHigh
    ln = line.new(bar_index - swingLen, ph, bar_index + 5, ph, color=color.new(color.red, 30), width=1)
    array.push(liqLines, ln)
    f_push_line(ln)
if useLiquidity and eqLow
    ln = line.new(bar_index - swingLen, pl, bar_index + 5, pl, color=color.new(color.green, 30), width=1)
    array.push(liqLines, ln)
    f_push_line(ln)

while array.size(liqLines) > 25
    oldL = array.shift(liqLines)
    if not na(oldL)
        line.delete(oldL)

liqSweepHigh = useLiquidity and not na(lastSwingHigh) and high > lastSwingHigh and close < lastSwingHigh
liqSweepLow = useLiquidity and not na(lastSwingLow) and low < lastSwingLow and close > lastSwingLow

plotshape(liqSweepHigh and showTier2 and not structMarkBear, title="Liquidity Grab High", style=shape.xcross,
     location=location.abovebar, color=color.new(color.red, 0), size=size.tiny)
plotshape(liqSweepLow and showTier2 and not structMarkBull, title="Liquidity Grab Low", style=shape.xcross,
     location=location.belowbar, color=color.new(color.green, 0), size=size.tiny)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// liq_alert_hub
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

alertcondition(liqSweepHigh, title="Liq Sweep High", message="Liquidity sweep high")
alertcondition(liqSweepLow, title="Liq Sweep Low", message="Liquidity sweep low")


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// liq_inducement
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

indLen = input.int(10, "Inducement Len", group=grpPlatform, tooltip="인듀스먼트(유인 스윕) 탐지 길이")
indHigh = ta.highest(high, indLen)
indLow = ta.lowest(low, indLen)
indBull = low < indLow[1] and close > indLow[1]
indBear = high > indHigh[1] and close < indHigh[1]
plotshape(showTier3 and (indBull), "Ind Bull", style=shape.xcross, location=location.belowbar, color=color.teal, size=size.tiny)
plotshape(showTier3 and (indBear), "Ind Bear", style=shape.xcross, location=location.abovebar, color=color.orange, size=size.tiny)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// liq_pool_zones
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

poolHigh = ta.highest(high, swingLen * 3)
poolLow = ta.lowest(low, swingLen * 3)
var box poolBox = na
if barstate.islastconfirmedhistory
    if not na(poolBox)
        box.delete(poolBox)
    poolBox := box.new(bar_index - swingLen * 3, poolHigh, bar_index, poolLow,
         bgcolor=color.new(color.gray, 92), border_color=color.new(color.gray, 70))
    f_push_box(poolBox)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// liq_session_high_low
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

sessHi = ta.highest(high, 24)
sessLo = ta.lowest(low, 24)
plot(sessHi, "Sess Hi", color=color.red, style=plot.style_linebr)
plot(sessLo, "Sess Lo", color=color.green, style=plot.style_linebr)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// liq_stop_hunt
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

stopHuntBull = low < liqCpLow[1] and close > liqCpLow[1]
stopHuntBear = high > liqCpHigh[1] and close < liqCpHigh[1]


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// liq_sweep — Liquidity Grab 확장
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

// liqSweepHigh/Low from liq_eqh_eql_lines
sweepReclaimBull = liqSweepLow[1] and close > lastSwingLow
sweepReclaimBear = liqSweepHigh[1] and close < lastSwingHigh
var int sweepBullCount = 0
var int sweepBearCount = 0
if liqSweepLow
    sweepBullCount += 1
if liqSweepHigh
    sweepBearCount += 1

bgcolor(not compactMode and sweepReclaimBull ? color.new(color.teal, 90) : not compactMode and sweepReclaimBear ? color.new(color.orange, 90) : na)
plotshape(showTier3 and not compactMode and sweepReclaimBull, title="Sweep Reclaim Bull", style=shape.diamond,
     location=location.belowbar, color=color.teal, size=size.small)
plotshape(showTier3 and not compactMode and sweepReclaimBear, title="Sweep Reclaim Bear", style=shape.diamond,
     location=location.abovebar, color=color.red, size=size.small)

var label sweepLbl = na
if liqSweepHigh and barstate.isconfirmed and not compactMode
    if not na(sweepLbl)
        label.delete(sweepLbl)
    sweepLbl := label.new(bar_index, high, "SWEEP H", style=label.style_label_down,
         color=color.red, textcolor=color.white, size=size.tiny)
if liqSweepLow and barstate.isconfirmed and not compactMode
    if not na(sweepLbl)
        label.delete(sweepLbl)
    sweepLbl := label.new(bar_index, low, "SWEEP L", style=label.style_label_up,
         color=color.green, textcolor=color.white, size=size.tiny)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// liq_void
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

voidLen = input.int(10, "Void Len", group=grpPlatform, tooltip="유동성 공백(void) 탐지 길이")
_voidAtr = ta.atr(14)
voidGap = (low - high[voidLen]) > _voidAtr * 0.3
bgcolor(showVolBg and voidGap ? color.new(color.fuchsia, 92) : na)
// [PLATFORM_END_LIQUIDITY]

// [PLATFORM_START_PATTERNS]

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// pat_chart_pattern
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

cpLen = input.int(20, "Chart Pat Len", group=grpPlatform, tooltip="차트 패턴 탐지 룩백 길이")
cpHigh = ta.highest(high, cpLen)
cpLow = ta.lowest(low, cpLen)
cpRange = cpHigh - cpLow
cpBull = close > cpLow + cpRange * 0.618 and close < cpHigh
cpBear = close < cpHigh - cpRange * 0.618 and close > cpLow
plotshape(showTier3 and (cpBull), "CP Bull", style=shape.triangleup, location=location.belowbar, color=color.green, size=size.tiny)
plotshape(showTier3 and (cpBear), "CP Bear", style=shape.triangledown, location=location.abovebar, color=color.red, size=size.tiny)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 14 - 패턴 인식 (Double Top/Bottom lite)
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

patLen = input.int(10, "패턴 룩백", minval=5, group=grpPlatform, tooltip="패턴 탐지 룩백 봉 수")
hh = ta.highest(high, patLen)
ll = ta.lowest(low, patLen)
doubleTop = useMarketStructure and not na(ph) and not na(ph[patLen]) and math.abs(ph - ph[patLen]) <= eqhTol
doubleBottom = useMarketStructure and not na(pl) and not na(pl[patLen]) and math.abs(pl - pl[patLen]) <= eqlTol

var line patLine = na
if doubleTop and barstate.isconfirmed
    if not na(patLine)
        line.delete(patLine)
    patLine := line.new(bar_index - patLen, ph, bar_index, ph, color=color.new(color.red, 20), width=2)
    f_push_line(patLine)
if doubleBottom and barstate.isconfirmed
    if not na(patLine)
        line.delete(patLine)
    patLine := line.new(bar_index - patLen, pl, bar_index, pl, color=color.new(color.green, 20), width=2)
    f_push_line(patLine)

plotshape(showTier3 and doubleTop, title="Double Top", style=shape.triangledown, location=location.abovebar, color=color.red, size=size.tiny)
plotshape(showTier3 and doubleBottom, title="Double Bottom", style=shape.triangleup, location=location.belowbar, color=color.green, size=size.tiny)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// pat_engulfing_pinbar — 캔들 패턴
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

pepWickRatio = input.float(0.6, "핀바 꼬리 비율", minval=0.3, maxval=0.9, step=0.05, group=grpPlatform, tooltip="봉 전체 범위 대비 꼬리 길이 비율 — 클수록 엄격한 핀바 판정")
// 이론: 장악형 = 직전 봉 매물 완전 흡수, 핀바 = 한쪽 극단 거부(rejection) 흔적
pepRange = math.max(high - low, syminfo.mintick)
pepBullEngulf = close > open and close[1] < open[1] and close >= open[1] and open <= close[1]
pepBearEngulf = close < open and close[1] > open[1] and close <= open[1] and open >= close[1]
pepLowerWick = math.min(open, close) - low
pepUpperWick = high - math.max(open, close)
pepPinUp = pepLowerWick / pepRange > pepWickRatio and close > open
pepPinDn = pepUpperWick / pepRange > pepWickRatio and close < open
plotshape(showTier3 and pepBullEngulf, "강세 장악형", shape.arrowup, location.belowbar, color.new(color.teal, 20), size=size.tiny)
plotshape(showTier3 and pepBearEngulf, "약세 장악형", shape.arrowdown, location.abovebar, color.new(color.orange, 20), size=size.tiny)
plotchar(showTier3 and pepPinUp, "강세 핀바", "P", location.belowbar, color.new(color.teal, 35), size=size.tiny)
plotchar(showTier3 and pepPinDn, "약세 핀바", "P", location.abovebar, color.new(color.orange, 35), size=size.tiny)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// pat_flag_pennant
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

fpLen = input.int(15, "Flag Len", group=grpPlatform, tooltip="깃발(Flag) 패턴 탐지 길이")
fpPole = close - close[fpLen]
fpConsol = ta.stdev(close, fpLen) / math.max(ta.atr(fpLen), syminfo.mintick)
flagBull = fpPole > 0 and fpConsol < 0.5
flagBear = fpPole < 0 and fpConsol < 0.5
plotshape(showTier3 and (flagBull), "Flag Bull", style=shape.flag, location=location.belowbar, color=color.teal, size=size.tiny)
plotshape(showTier3 and (flagBear), "Flag Bear", style=shape.flag, location=location.abovebar, color=color.orange, size=size.tiny)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// pat_fs_pattern_fsm
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

var int patFsm = 0
if ta.pivothigh(high, 5, 5)
    patFsm := 1
if ta.pivotlow(low, 5, 5)
    patFsm := -1
bgcolor(showSigBg and patFsm == 1 ? color.new(color.green, 97) : patFsm == -1 ? color.new(color.red, 97) : na)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// pat_harmonic_osc
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

harmLen = input.int(14, "Harmonic Len", group=grpPlatform, tooltip="하모닉 진동 계산 기간")
harmOsc = ta.rsi(close, harmLen) - 50
plot(harmOsc, "Harmonic Osc", color=color.fuchsia, display=display.pane)
hline(20, "Harm OB", color=color.red)
hline(-20, "Harm OS", color=color.green)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// pat_pattern_alert
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

alertcondition(patFsm == 1, title="Pattern Bull FSM", message="Pattern bull FSM active")
alertcondition(patFsm == -1, title="Pattern Bear FSM", message="Pattern bear FSM active")


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// pat_r2_filter
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

r2Len = input.int(20, "R2 Len", group=grpPlatform, tooltip="결정계수(R²) 계산 기간 — 추세 품질 판정")
r2Mid = ta.sma(close, r2Len)
r2Dev = ta.stdev(close, r2Len)
r2Score = 1 - r2Dev / math.max(ta.atr(r2Len), syminfo.mintick)
plot(r2Score, "R2 Filter", color=color.blue, display=display.pane)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// pat_head_shoulders
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

hsLen = input.int(30, "H&S Lookback", minval=10, group=grpPlatform, tooltip="헤드앤숄더 탐지 룩백 봉 수")
ls = ta.pivotlow(low, 3, 3)
rs = ta.pivotlow(low, 3, 3)
head = ta.pivotlow(low, 5, 5)
hsPattern = not na(ls) and not na(rs) and not na(head) and head < ls and head < rs
neckline = (ls + rs) / 2
_crossHsDn = ta.crossunder(close, neckline)
hsBreak = hsPattern and _crossHsDn
plot(neckline, "H&S Neckline", color=color.gray, style=plot.style_circles)
plotshape(showTier3 and (hsPattern), title="H&S Forming", style=shape.labeldown, location=location.abovebar, color=color.red, text="H&S", size=size.tiny)
plotshape(showTier3 and (hsBreak), title="H&S Break", style=shape.triangledown, location=location.abovebar, color=color.fuchsia, size=size.small)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// pat_triangle
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

triLen = input.int(20, "Triangle Lookback", minval=5, group=grpPlatform, tooltip="삼각수렴 패턴 탐지 룩백")
triHigh = ta.highest(high, triLen)
triLow = ta.lowest(low, triLen)
triRange = triHigh - triLow
triCompress = triRange < triRange[5] * 0.7
triUpper = triHigh - triRange * 0.15
triLower = triLow + triRange * 0.15
_crossTriUp = ta.crossover(close, triUpper)
_crossTriDn = ta.crossunder(close, triLower)
triBreakUp = triCompress and _crossTriUp
triBreakDn = triCompress and _crossTriDn
plot(triUpper, "Tri Upper", color=color.new(color.red, 50))
plot(triLower, "Tri Lower", color=color.new(color.green, 50))
plotshape(showTier3 and (triBreakUp), title="Tri Break Up", style=shape.triangleup, location=location.belowbar, color=color.green, size=size.tiny)
plotshape(showTier3 and (triBreakDn), title="Tri Break Dn", style=shape.triangledown, location=location.abovebar, color=color.red, size=size.tiny)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// pat_wedge
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

wedgeLen = input.int(15, "Wedge Lookback", minval=5, group=grpPlatform, tooltip="쐐기(Wedge) 패턴 탐지 룩백")
wHigh1 = ta.highest(high, wedgeLen)
wLow1 = ta.lowest(low, wedgeLen)
wHigh2 = ta.highest(high, wedgeLen / 2)
wLow2 = ta.lowest(low, wedgeLen / 2)
risingWedge = wHigh2 < wHigh1 and wLow2 > wLow1
fallingWedge = wHigh2 > wHigh1 and wLow2 < wLow1
plotshape(showTier3 and (risingWedge), title="Rising Wedge", style=shape.xcross, location=location.abovebar, color=color.orange, size=size.tiny)
plotshape(showTier3 and (fallingWedge), title="Falling Wedge", style=shape.xcross, location=location.belowbar, color=color.teal, size=size.tiny)
// [PLATFORM_END_PATTERNS]

// [PLATFORM_START_TRENDLINES]

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 15 - 추세선 유동성 존
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

var line upTrend = na
var line dnTrend = na
var float slopeUp = na
var float slopeDn = na

if useMarketStructure and not na(pl) and not na(pl[swingLen])
    if not na(upTrend)
        line.delete(upTrend)
    upTrend := line.new(bar_index - swingLen, pl[swingLen], bar_index, pl, color=color.new(color.green, 40), width=1, extend=extend.right)
    f_push_line(upTrend)
    slopeUp := (pl - pl[swingLen]) / swingLen

if useMarketStructure and not na(ph) and not na(ph[swingLen])
    if not na(dnTrend)
        line.delete(dnTrend)
    dnTrend := line.new(bar_index - swingLen, ph[swingLen], bar_index, ph, color=color.new(color.red, 40), width=1, extend=extend.right)
    f_push_line(dnTrend)
    slopeDn := (ph - ph[swingLen]) / swingLen

tlBreakUp = not na(slopeUp) and close > line.get_price(upTrend, bar_index)
tlBreakDn = not na(slopeDn) and close < line.get_price(dnTrend, bar_index)

plotshape(showTier3 and tlBreakUp, title="Trendline Break Up", style=shape.circle, location=location.belowbar, color=color.teal, size=size.tiny)
plotshape(showTier3 and tlBreakDn, title="Trendline Break Dn", style=shape.circle, location=location.abovebar, color=color.orange, size=size.tiny)
// [PLATFORM_END_TRENDLINES]

// [PLATFORM_START_LABELS]

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 17 - 구조 라벨 (스윙 태깅)
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

// declutter: 스윙 태그는 보조 정보 — Full 프로필(showTier3)에서만, 최근 30개 유지
var array<label> structLabels = array.new_label()

if useMarketStructure and showTier3 and not na(ph) and barstate.isconfirmed
    lb = label.new(bar_index - swingLen, ph, "SH", style=label.style_label_down, color=color.new(color.red, 30), textcolor=color.white, size=size.tiny)
    array.push(structLabels, lb)
    f_push_label(lb)
if useMarketStructure and showTier3 and not na(pl) and barstate.isconfirmed
    lb = label.new(bar_index - swingLen, pl, "SL", style=label.style_label_up, color=color.new(color.green, 30), textcolor=color.white, size=size.tiny)
    array.push(structLabels, lb)
    f_push_label(lb)

while array.size(structLabels) > 30
    oldLb = array.shift(structLabels)
    if not na(oldLb)
        label.delete(oldLb)
// [PLATFORM_END_LABELS]

// [PLATFORM_START_MOMENTUM]

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// mt_adx_filter
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

adxLen = input.int(14, "ADX Len", group=grpPlatform, tooltip="ADX 계산 기간 — 추세 강도 판정 기준")
[diPlus, diMinus, adxVal] = ta.dmi(adxLen, adxLen)
adxTrend = adxVal > 25
plot(adxVal, "ADX", color=color.gray, display=display.pane)
bgcolor(showSigBg and adxTrend ? color.new(color.blue, 97) : na)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// mt_cci_reversal
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

cciLen = input.int(20, "CCI Len", group=grpPlatform, tooltip="CCI 계산 기간")
cciVal = ta.cci(close, cciLen)
cciRevBull = ta.crossover(cciVal, -100)
cciRevBear = ta.crossunder(cciVal, 100)
plot(cciVal, "CCI", color=color.orange, display=display.pane)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// mt_divergence_rsi
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

divRsiLen = input.int(14, "Div RSI", group=grpPlatform, tooltip="다이버전스 탐지용 RSI 기간")
divRsi = ta.rsi(close, divRsiLen)
divBull = ta.lowest(low, 10) == low and divRsi > divRsi[10]
divBear = ta.highest(high, 10) == high and divRsi < divRsi[10]
plotshape(showTier3 and (divBull), "Div Bull", style=shape.circle, location=location.belowbar, color=color.green, size=size.tiny)
plotshape(showTier3 and (divBear), "Div Bear", style=shape.circle, location=location.abovebar, color=color.red, size=size.tiny)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// mt_ema_stack
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

ema8 = ta.ema(close, 8)
ema21 = ta.ema(close, 21)
ema55 = ta.ema(close, 55)
emaStackBull = ema8 > ema21 and ema21 > ema55
emaStackBear = ema8 < ema21 and ema21 < ema55
plot(ema8, "EMA8", color=color.new(color.aqua, 0))
plot(ema21, "EMA21", color=color.new(color.yellow, 0))
plot(ema55, "EMA55", color=color.new(color.orange, 0))
bgcolor(showSigBg and emaStackBull ? color.new(color.teal, 95) : showSigBg and emaStackBear ? color.new(color.red, 95) : na)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// mt_exhaustion_count — 추세 소진 카운트
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

exhShowNum = input.bool(true, "소진 카운트 표시", group=grpPlatform, tooltip="4봉 전 종가 비교 연속 카운트가 8·9에 도달하면 소진 후보로 표시합니다")
// 이론: 같은 방향 4봉-비교가 9회 연속되면 추세 참여자 소진 가능성 (DeMark 계열)
var int exhUp = 0
var int exhDn = 0
exhUp := close > close[4] ? exhUp + 1 : 0
exhDn := close < close[4] ? exhDn + 1 : 0
exhTop = exhUp == 9
exhBot = exhDn == 9
plotshape(showTier3 and exhShowNum and exhUp == 8, "소진 8 ↑", shape.circle, location.abovebar, color.new(color.orange, 55), size=size.tiny)
plotshape(showTier2 and exhShowNum and exhTop, "매수 소진 9", shape.labeldown, location.abovebar, color.new(color.orange, 10), text="9", textcolor=color.white, size=size.tiny)
plotshape(showTier3 and exhShowNum and exhDn == 8, "소진 8 ↓", shape.circle, location.belowbar, color.new(color.teal, 55), size=size.tiny)
plotshape(showTier2 and exhShowNum and exhBot, "매도 소진 9", shape.labelup, location.belowbar, color.new(color.teal, 10), text="9", textcolor=color.white, size=size.tiny)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// mt_hma_osc
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

hmaLen = input.int(20, "HMA Len", group=grpPlatform, tooltip="Hull MA 기간 — 작을수록 민감")
hmaVal = ta.hma(close, hmaLen)
hmaOsc = (close - hmaVal) / math.max(ta.atr(14), syminfo.mintick)
plot(hmaOsc, "HMA Osc", color=color.teal, display=display.pane)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// mt_ma_cross
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

maFast = input.int(9, "Fast MA", group=grpPlatform, tooltip="빠른 이동평균 기간")
maSlow = input.int(21, "Slow MA", group=grpPlatform, tooltip="느린 이동평균 기간")
maCrossFast = ta.ema(close, maFast)
maCrossSlow = ta.ema(close, maSlow)
maCrossBull = ta.crossover(maCrossFast, maCrossSlow)
maCrossBear = ta.crossunder(maCrossFast, maCrossSlow)
plot(maCrossFast, "Fast", color=color.green)
plot(maCrossSlow, "Slow", color=color.red)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// mt_macd_suite
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

[macdLine, macdSignal, macdHist] = ta.macd(close, 12, 26, 9)
macdBull = ta.crossover(macdLine, macdSignal)
macdBear = ta.crossunder(macdLine, macdSignal)
plot(macdHist, "MACD Hist", color=color.gray, display=display.pane)
plotshape(showTier3 and macdBull, title="MACD Bull", style=shape.triangleup, location=location.belowbar, color=color.green, size=size.tiny)
plotshape(showTier3 and macdBear, title="MACD Bear", style=shape.triangledown, location=location.abovebar, color=color.red, size=size.tiny)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// mt_momentum_osc
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

momLen = input.int(10, "Mom Len", group=grpPlatform, tooltip="모멘텀 계산 기간")
momVal = ta.mom(close, momLen)
plot(momVal, "Momentum", color=color.blue, display=display.pane)
hline(0, "Zero", color=color.gray)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// mt_regime_filter
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

regLen = input.int(50, "Regime Len", group=grpPlatform, tooltip="레짐(추세/횡보) 판정 기간")
regEma = ta.ema(close, regLen)
regAtr = ta.atr(regLen)
regTrend = close > regEma + regAtr ? 1 : close < regEma - regAtr ? -1 : 0
bgcolor(showSigBg and regTrend == 1 ? color.new(color.green, 97) : regTrend == -1 ? color.new(color.red, 97) : na)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// mt_rsi_suite
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

rsiLenMt = input.int(14, "RSI", group=grpPlatform, tooltip="RSI 계산 기간")
rsiMt = ta.rsi(close, rsiLenMt)
rsiOb = rsiMt > 70
rsiOs = rsiMt < 30
plot(rsiMt, "RSI", color=color.purple, display=display.pane)
hline(70, "OB", color=color.red)
hline(30, "OS", color=color.green)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// mt_squeeze_detector — 변동성 스퀴즈
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

sqzLen = input.int(20, "스퀴즈 기간", minval=5, group=grpPlatform, tooltip="볼린저 밴드·켈트너 채널 계산 기간")
sqzBbMult = input.float(2.0, "BB 배수", minval=0.5, step=0.1, group=grpPlatform, tooltip="볼린저 밴드 표준편차 배수")
sqzKcMult = input.float(1.5, "KC 배수", minval=0.5, step=0.1, group=grpPlatform, tooltip="켈트너 채널 ATR 배수")
[sqzBbM, sqzBbU, sqzBbL] = ta.bb(close, sqzLen, sqzBbMult)
[sqzKcM, sqzKcU, sqzKcL] = ta.kc(close, sqzLen, sqzKcMult)
// 스퀴즈: BB가 KC 안으로 수축 = 변동성 압축 → 해제 시 방향성 분출 가능성
sqzOn = sqzBbU < sqzKcU and sqzBbL > sqzKcL
sqzFired = sqzOn[1] and not sqzOn
sqzMom = ta.linreg(close - math.avg(ta.highest(high, sqzLen), ta.lowest(low, sqzLen), ta.sma(close, sqzLen)), sqzLen, 0)
sqzFireUp = sqzFired and sqzMom > 0
sqzFireDn = sqzFired and sqzMom < 0
plotshape(showTier2 and sqzFireUp, "스퀴즈 해제 ↑", shape.triangleup, location.belowbar, color.new(color.teal, 0), size=size.small)
plotshape(showTier2 and sqzFireDn, "스퀴즈 해제 ↓", shape.triangledown, location.abovebar, color.new(color.orange, 0), size=size.small)
plotchar(showTier3 and sqzOn, "스퀴즈 압축", "•", location.bottom, color.new(color.gray, 30), size=size.tiny)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// mt_stoch_suite
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

stochK = input.int(14, "Stoch K", group=grpPlatform, tooltip="스토캐스틱 %K 기간")
stochD = input.int(3, "Stoch D", group=grpPlatform, tooltip="스토캐스틱 %D 평활 기간")
kVal = ta.stoch(close, high, low, stochK)
dVal = ta.sma(kVal, stochD)
plot(kVal, "Stoch K", color=color.blue, display=display.pane)
plot(dVal, "Stoch D", color=color.orange, display=display.pane)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// mt_supertrend
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

[st, dir] = ta.supertrend(3.0, 10)
plot(st, "SuperTrend", color=dir < 0 ? color.green : color.red, linewidth=2)
stBull = dir < 0
stBear = dir > 0


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// mt_trend_strength
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

tsLen = input.int(20, "Trend Str Len", group=grpPlatform, tooltip="추세 강도 계산 기간")
tsEma = ta.ema(close, tsLen)
tsStr = (close - tsEma) / math.max(ta.atr(tsLen), syminfo.mintick)
plot(tsStr, "Trend Strength", color=color.purple, display=display.pane)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// mt_zero_lag_ema
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

zleLen = input.int(21, "ZLE Len", group=grpPlatform, tooltip="제로랙 EMA 기간")
zleEma1 = ta.ema(close, zleLen)
zleEma2 = ta.ema(zleEma1, zleLen)
zle = 2 * zleEma1 - zleEma2
plot(zle, "Zero Lag EMA", color=color.yellow)
// [PLATFORM_END_MOMENTUM]

// [PLATFORM_START_SIGNAL_VARS]

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// sig_confirmation
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

confirmLong = bosUp and pdDiscount and hierarchyBull
confirmShort = bosDn and pdPremium and hierarchyBear
plotshape(showTier2 and confirmLong, title="Confirm Long", style=shape.labelup, location=location.belowbar, color=color.lime, text="C", size=size.tiny)
plotshape(showTier2 and confirmShort, title="Confirm Short", style=shape.labeldown, location=location.abovebar, color=color.red, text="C", size=size.tiny)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 12 - 시그널 합류 (confluence score)
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

confLong = 0
confShort = 0
if bosUp or chochUp
    confLong += 1
if bosDn or chochDn
    confShort += 1
if bullFvg
    confLong += 1
if bearFvg
    confShort += 1
if msTrend > 0
    confLong += 1
if msTrend < 0
    confShort += 1
if liqSweepLow
    confLong += 1
if liqSweepHigh
    confShort += 1

confluenceLong = confLong >= 2
confluenceShort = confShort >= 2
plotchar(showTier3 and confluenceLong, title="Confluence Long", char="▲", location=location.belowbar, color=color.teal, size=size.tiny)
plotchar(showTier3 and confluenceShort, title="Confluence Short", char="▼", location=location.abovebar, color=color.orange, size=size.tiny)
// [PLATFORM_END_SIGNAL_VARS]

// [PLATFORM_START_CORE]
// [AI_START_LOGIC]
longSignal = confluenceLong and emaStackBull and hierarchyBull
shortSignal = confluenceShort and emaStackBear and hierarchyBear
// [AI_END_LOGIC]
// [PLATFORM_END_CORE]

// [PLATFORM_START_CONFLUENCE]

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// sig_bar_color
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

barColorBull = confluenceLong or emaStackBull
barColorBear = confluenceShort or emaStackBear
barcolor(barColorBull ? color.new(color.green, 70) : barColorBear ? color.new(color.red, 70) : na)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// sig_bgcolor_zone
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

bgcolor(showTier2 and showSigBg and confluenceLong ? color.new(color.teal, 92) : showTier2 and showSigBg and confluenceShort ? color.new(color.orange, 92) : na)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// sig_contrarian
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

contRsi = ta.rsi(close, 14)
contLong = contRsi < 25 and close > open
contShort = contRsi > 75 and close < open


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// sig_multi_channel_alert
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

alertcondition(useAlertHub and longSignal, title="Multi Long", message="Multi-channel long")
alertcondition(useAlertHub and shortSignal, title="Multi Short", message="Multi-channel short")


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// sig_notifier
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

alert(longSignal ? "Long signal" : na, alert.freq_once_per_bar_close)
alert(shortSignal ? "Short signal" : na, alert.freq_once_per_bar_close)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// sig_one_per_leg
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

var int lastLeg = 0
onePerLegLong = longSignal and lastLeg != 1
onePerLegShort = shortSignal and lastLeg != -1
if onePerLegLong
    lastLeg := 1
if onePerLegShort
    lastLeg := -1


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// sig_reversal_zones
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

revZoneHigh = ta.highest(high, 50)
revZoneLow = ta.lowest(low, 50)
_revRsi = ta.rsi(close, 14)
revLong = close <= revZoneLow * 1.01 and _revRsi < 30
revShort = close >= revZoneHigh * 0.99 and _revRsi > 70


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// sig_smart_trail
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

smartTrail = ta.ema(close, 21) - ta.atr(14) * 1.5
plot(smartTrail, "Smart Trail", color=color.orange, style=plot.style_linebr)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// sig_staged_pre_confirm
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

preLong = bosUp and not confirmLong
preShort = bosDn and not confirmShort
plotshape(showTier3 and preLong, title="Pre Long", style=shape.circle, location=location.belowbar, color=color.yellow, size=size.tiny)
plotshape(showTier3 and preShort, title="Pre Short", style=shape.circle, location=location.abovebar, color=color.yellow, size=size.tiny)
// [PLATFORM_END_CONFLUENCE]

// [PLATFORM_START_SCORE]

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// exec_atr_sl_tp
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

riskAtrLen = input.int(14, "ATR Length", group=grpPlatform, tooltip="손절 폭 계산용 ATR 기간")
slAtrMult = input.float(1.5, "SL ATR Mult", group=grpPlatform, tooltip="손절 거리 = ATR × 이 배수")
tpRR = input.float(2.5, "TP RR", group=grpPlatform, tooltip="익절 거리 = 손절 거리 × 이 손익비")
riskAtr = ta.atr(riskAtrLen)
stopLoss = close - riskAtr * slAtrMult
takeProfit = close + riskAtr * slAtrMult * tpRR
plot(stopLoss, "SL", color=color.red, style=plot.style_linebr)
plot(takeProfit, "TP", color=color.green, style=plot.style_linebr)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// exec_backtest_hints
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

// 백테스트 힌트 — calc_on_every_tick 비활성 권장
// strategy.risk.max_drawdown 등은 idea 레벨에서 설정


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// exec_bracket_orders
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

bracketAtr = input.float(1.5, "Bracket ATR", group=grpPlatform, tooltip="브래킷 레벨 폭 = ATR × 이 배수")
bracketTp = close + ta.atr(14) * bracketAtr
bracketSl = close - ta.atr(14) * bracketAtr
plot(bracketTp, "Bracket TP", color=color.green, style=plot.style_linebr)
plot(bracketSl, "Bracket SL", color=color.red, style=plot.style_linebr)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// exec_exit_signal
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

exitAtr = ta.atr(14)
exitLong = close < ta.ema(close, 20) - exitAtr
exitShort = close > ta.ema(close, 20) + exitAtr


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// exec_position_sizing
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

posRiskPct = input.float(1.0, "Risk %", group=grpPlatform, tooltip="1회 트레이드 허용 리스크 비율(%)")
posAtr = ta.atr(14)
posSize = strategy.equity * posRiskPct / 100 / math.max(posAtr, syminfo.mintick)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// exec_same_bar_rules
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

// 동일 봉 진입/청산 방지 게이트
sameBarOk = bar_index != ta.valuewhen(strategy.position_size[1] == 0 and strategy.position_size != 0, bar_index, 0)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// exec_strategy_entry_engine
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

entryEma = ta.ema(close, 21)
entryTrendUp = close > entryEma and entryEma > entryEma[1]
entryTrendDn = close < entryEma and entryEma < entryEma[1]


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// exec_tp_ladder
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

tpAtr = ta.atr(14)
tp1 = strategy.position_avg_price + tpAtr
tp2 = strategy.position_avg_price + tpAtr * 2
tp3 = strategy.position_avg_price + tpAtr * 3
plot(strategy.position_size > 0 ? tp1 : na, "TP1", color=color.green, style=plot.style_linebr)
plot(strategy.position_size > 0 ? tp2 : na, "TP2", color=color.lime, style=plot.style_linebr)
plot(strategy.position_size > 0 ? tp3 : na, "TP3", color=color.teal, style=plot.style_linebr)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// exec_trade_box_fsm
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

var int tradeFsm = 0
if longCondition and tradeFsm == 0
    tradeFsm := 1
if shortCondition and tradeFsm == 0
    tradeFsm := -1
if strategy.position_size == 0
    tradeFsm := 0
bgcolor(showSigBg and tradeFsm == 1 ? color.new(color.green, 95) : tradeFsm == -1 ? color.new(color.red, 95) : na)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// exec_trailing_stop
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

trailAtr = input.float(2.0, "Trail ATR", group=grpPlatform, tooltip="트레일링 스탑 폭 = ATR × 이 배수")
trailStop = close - ta.atr(14) * trailAtr
var float trailLevel = na
if strategy.position_size > 0
    trailLevel := math.max(nz(trailLevel, trailStop), trailStop)
else
    trailLevel := na
plot(trailLevel, "Trail Stop", color=color.orange, style=plot.style_linebr)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// qx_accuracy_dashboard
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

var table qxAcc = table.new(position.middle_right, 2, 4, border_width=1)
if barstate.islast
    table.cell(qxAcc, 0, 0, "QX ACC", text_size=size.tiny, bgcolor=color.new(color.gray, 80))
    table.cell(qxAcc, 1, 0, "VAL", text_size=size.tiny, bgcolor=color.new(color.gray, 80))
    table.cell(qxAcc, 0, 1, "LinReg", text_size=size.tiny)
    table.cell(qxAcc, 1, 1, str.tostring(lr, "#.##"), text_size=size.tiny)
    table.cell(qxAcc, 0, 2, "Z", text_size=size.tiny)
    table.cell(qxAcc, 1, 2, str.tostring(zVal, "#.##"), text_size=size.tiny)
    table.cell(qxAcc, 0, 3, "Bias", text_size=size.tiny)
    table.cell(qxAcc, 1, 3, close > lr ? "BULL" : "BEAR", text_size=size.tiny)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// qx_correlation_matrix
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

corrLen = input.int(20, "Corr Len", group=grpPlatform, tooltip="상관계수 계산 기간")
corrSym = input.symbol("SPY", "Corr Symbol", group=grpPlatform, tooltip="상관관계를 비교할 기준 심볼")
corrClose = request.security(corrSym, timeframe.period, close, barmerge.gaps_off, barmerge.lookahead_off)
corrVal = ta.correlation(close, corrClose, corrLen)
plot(corrVal, "Correlation", color=color.purple, display=display.pane)
hline(0.7, "Strong+", color=color.green)
hline(-0.7, "Strong-", color=color.red)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// qx_cross_venue_matrix
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

cvLen = input.int(14, "CV Len", group=grpPlatform, tooltip="변동계수(CV) 계산 기간")
cvA = request.security(syminfo.tickerid, "60", close, barmerge.gaps_off, barmerge.lookahead_off)
cvB = request.security(syminfo.tickerid, "240", close, barmerge.gaps_off, barmerge.lookahead_off)
cvSpread = (cvA - cvB) / math.max(ta.atr(cvLen), syminfo.mintick)
plot(cvSpread, "CV Spread", color=color.teal, display=display.pane)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// qx_expectile_bands
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

expLen = input.int(20, "Expectile Len", group=grpPlatform, tooltip="Expectile 회귀 계산 기간")
expMid = ta.sma(close, expLen)
expDev = ta.stdev(close, expLen)
expUpper = expMid + expDev * 1.5
expLower = expMid - expDev * 1.5
plot(expMid, "Expectile Mid", color=color.blue)
plot(expUpper, "Expectile Upper", color=color.red)
plot(expLower, "Expectile Lower", color=color.green)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// qx_external_security
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

extSym = input.symbol("QQQ", "External", group=grpPlatform, tooltip="외부 참조 심볼 — 시장 대비 상대 강도")
extTf = input.timeframe("D", "External TF", group=grpPlatform, tooltip="외부 심볼 참조 시간대")
extClose = request.security(extSym, extTf, close, barmerge.gaps_off, barmerge.lookahead_off)
extEma = ta.ema(extClose, 20)
plot(extClose, "Ext Close", color=color.gray, display=display.pane)
plot(extEma, "Ext EMA", color=color.orange, display=display.pane)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// qx_linreg_forecast
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

linLen = input.int(20, "LinReg Len", group=grpPlatform, tooltip="선형회귀 계산 기간")
lr = ta.linreg(close, linLen, 0)
plot(lr, "LinReg", color=color.blue)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// qx_ols_channel
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

olsLen = input.int(20, "OLS Len", group=grpPlatform, tooltip="OLS 회귀 계산 기간")
olsMid = ta.linreg(close, olsLen, 0)
olsDev = ta.stdev(close, olsLen)
olsUpper = olsMid + olsDev * 2
olsLower = olsMid - olsDev * 2
plot(olsMid, "OLS Mid", color=color.blue)
plot(olsUpper, "OLS Upper", color=color.red)
plot(olsLower, "OLS Lower", color=color.green)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// qx_onchain_gauge
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

gaugeLen = input.int(14, "Gauge Len", group=grpPlatform, tooltip="게이지 정규화 계산 기간")
gaugeMom = ta.roc(close, gaugeLen)
gaugeNorm = gaugeMom / math.max(ta.stdev(gaugeMom, gaugeLen), 0.001)
plot(gaugeNorm, "OnChain Gauge", color=color.yellow, display=display.pane)
bgcolor(showSigBg and gaugeNorm > 1 ? color.new(color.green, 92) : gaugeNorm < -1 ? color.new(color.red, 92) : na)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// qx_simulation_cone
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

coneLen = input.int(20, "Cone Len", group=grpPlatform, tooltip="예측 콘(변동성 원뿔) 계산 기간")
coneMid = ta.linreg(close, coneLen, 0)
coneSlope = (coneMid - coneMid[coneLen]) / coneLen
coneUpper = coneMid + coneSlope * 5 + ta.stdev(close, coneLen)
coneLower = coneMid + coneSlope * 5 - ta.stdev(close, coneLen)
plot(coneMid, "Cone Mid", color=color.blue)
plot(coneUpper, "Cone Upper", color=color.red, style=plot.style_linebr)
plot(coneLower, "Cone Lower", color=color.green, style=plot.style_linebr)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// qx_zscore_bands
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

zLen = input.int(20, "Z Len", group=grpPlatform, tooltip="Z-Score 계산 기간")
zVal = (close - ta.sma(close, zLen)) / ta.stdev(close, zLen)
plot(zVal, "Z", color=color.purple, display=display.pane)
hline(2, "Z+2", color=color.red)
hline(-2, "Z-2", color=color.green)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 18 - 프리미엄 스코어 (0–10)
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
score = 0.0
score += msTrend > 0 ? 2.0 : msTrend < 0 ? -2.0 : 0.0
score += bullFvg ? 1.5 : bearFvg ? -1.5 : 0.0
score += confluenceLong ? 2.0 : confluenceShort ? -2.0 : 0.0
score += imbalanceUp ? 1.0 : imbalanceDn ? -1.0 : 0.0
score += liqSweepLow ? 1.5 : liqSweepHigh ? -1.5 : 0.0
score += inNy ? 0.5 : 0.0
score := math.max(math.min(score, 10.0), -10.0)

scoreColor = score > 3 ? color.teal : score < -3 ? color.orange : color.gray
plot(score, "Premium Score", color=scoreColor, linewidth=2)
hline(0, "Zero", color=color.gray)
// [PLATFORM_END_SCORE]

// [PLATFORM_START_MTF]

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 08 - MTF 데이터
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
mtf0 = request.security(syminfo.tickerid, "15", close > ta.ema(close, 50), barmerge.gaps_off, barmerge.lookahead_off)
mtf1 = request.security(syminfo.tickerid, "60", close > ta.ema(close, 50), barmerge.gaps_off, barmerge.lookahead_off)
mtf2 = request.security(syminfo.tickerid, "240", close > ta.ema(close, 50), barmerge.gaps_off, barmerge.lookahead_off)
mtf3 = request.security(syminfo.tickerid, "D", close > ta.ema(close, 50), barmerge.gaps_off, barmerge.lookahead_off)
// [PLATFORM_END_MTF]

// [PLATFORM_START_ALERTS]

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 09 - 알림 허브
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

alertcondition(useAlertHub and bosUp, title="Full_Platform_SKU08 BOS Up", message="Full_Platform_SKU08 BOS Bullish on {ticker}")
alertcondition(useAlertHub and bosDn, title="Full_Platform_SKU08 BOS Dn", message="Full_Platform_SKU08 BOS Bearish on {ticker}")
alertcondition(useAlertHub and chochUp, title="Full_Platform_SKU08 CHoCH Up", message="Full_Platform_SKU08 CHoCH Bullish")
alertcondition(useAlertHub and chochDn, title="Full_Platform_SKU08 CHoCH Dn", message="Full_Platform_SKU08 CHoCH Bearish")
alertcondition(useAlertHub and bullFvg, title="Full_Platform_SKU08 Bull FVG", message="Full_Platform_SKU08 Bull FVG formed")
alertcondition(useAlertHub and bearFvg, title="Full_Platform_SKU08 Bear FVG", message="Full_Platform_SKU08 Bear FVG formed")
alertcondition(useAlertHub and liqSweepHigh, title="Full_Platform_SKU08 Liq Grab High", message="Full_Platform_SKU08 Liquidity sweep high")
alertcondition(useAlertHub and liqSweepLow, title="Full_Platform_SKU08 Liq Grab Low", message="Full_Platform_SKU08 Liquidity sweep low")
alertcondition(useAlertHub and longSignal, title="Full_Platform_SKU08 Long Signal", message="Full_Platform_SKU08 LONG signal")
alertcondition(useAlertHub and shortSignal, title="Full_Platform_SKU08 Short Signal", message="Full_Platform_SKU08 SHORT signal")
if useAlertHub and barstate.isconfirmed and (longSignal or shortSignal)
    alert("Full_Platform_SKU08 " + (longSignal ? "LONG" : "SHORT") + " | " + syminfo.ticker + " @ " + str.tostring(close, format.mintick), alert.freq_once_per_bar_close)

confirmOk = barstate.isconfirmed


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// resource_limits
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

// resource limits in indicator() header


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// section_headers
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

// module section headers via sec()


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 알림
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

alertcondition(longSignal, title="Full_Platform_SKU08 Long Signal", message="Full_Platform_SKU08 long signal on {ticker}")
alertcondition(shortSignal, title="Full_Platform_SKU08 Short Signal", message="Full_Platform_SKU08 short signal on {ticker}")
// [PLATFORM_END_ALERTS]

// [PLATFORM_START_DASHBOARD]

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// ui_alert_log_panel — 시그널 로그
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

alogShow = input.bool(false, "시그널 로그 패널", group=grpVisual, tooltip="최근 시그널의 발생 시각과 방향을 기록한 로그 패널을 표시합니다")
var array<string> alogRows = array.new<string>()
if confluenceLong and not confluenceLong[1]
    array.unshift(alogRows, "▲ LONG  " + str.format_time(time, "MM-dd HH:mm", syminfo.timezone))
if confluenceShort and not confluenceShort[1]
    array.unshift(alogRows, "▼ SHORT " + str.format_time(time, "MM-dd HH:mm", syminfo.timezone))
if array.size(alogRows) > 6
    array.pop(alogRows)
var table alogTbl = table.new(position.middle_left, 1, 7, bgcolor=color.new(color.black, 85), border_width=1, border_color=color.new(color.gray, 80))
if alogShow and barstate.islast and array.size(alogRows) > 0
    table.cell(alogTbl, 0, 0, "최근 시그널", text_size=size.tiny, text_color=color.new(color.white, 10), bgcolor=color.new(color.gray, 70))
    for alogI = 0 to math.min(array.size(alogRows), 6) - 1
        table.cell(alogTbl, 0, alogI + 1, array.get(alogRows, alogI), text_size=size.tiny, text_color=color.new(color.white, 30), text_halign=text.align_left)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// ui_compact_mode
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// compactMode — see grpVisual in platform master inputs


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// ui_full_mode
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

fullMode = input.bool(false, "Full UI Mode", group=grpPlatform, tooltip="모든 보조 요소를 표시하는 풀 UI 모드")


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// ui_gradient_bar_coloring — 그라디언트 캔들
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

gbarOn = input.bool(false, "그라디언트 캔들", group=grpVisual, tooltip="추세 강도에 따라 캔들 색을 주황(약세)–청록(강세) 그라디언트로 칠합니다")
gbarLen = input.int(50, "그라디언트 기준 EMA", minval=5, group=grpVisual, tooltip="추세 강도 계산의 기준 EMA 기간")
gbarEma = ta.ema(close, gbarLen)
gbarAtr = ta.atr(14)
gbarScore = math.max(-3.0, math.min(3.0, (close - gbarEma) / math.max(gbarAtr, syminfo.mintick)))
gbarColor = color.from_gradient(gbarScore, -3, 3, color.new(color.orange, 0), color.new(color.teal, 0))
barcolor(gbarOn ? gbarColor : na)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// ui_heatmap_bg
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

showHeatmap = input.bool(false, "RSI 히트맵 배경", group=grpVisual, tooltip="RSI 과매수(70+)·과매도(30-) 구간을 배경 음영으로 표시합니다")
heatVal = ta.rsi(close, 14)
bgcolor(showHeatmap and heatVal > 70 ? color.new(color.red, 92) : showHeatmap and heatVal < 30 ? color.new(color.green, 92) : na)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// ui_perf_stats_panel — 성과 요약 패널
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

perfpShow = input.bool(true, "성과 요약 패널", group=grpVisual, tooltip="합류 시그널 발생 후 N봉 뒤 방향 적중률을 실시간 집계해 표시합니다")
perfpHorizon = input.int(10, "성과 측정 봉 수", minval=1, maxval=100, group=grpVisual, tooltip="시그널 발생 후 몇 봉 뒤 가격으로 적중 여부를 판정할지")
var int perfpWinL = 0
var int perfpTotL = 0
var int perfpWinS = 0
var int perfpTotS = 0
if confluenceLong[perfpHorizon]
    perfpTotL := perfpTotL + 1
    if close > close[perfpHorizon]
        perfpWinL := perfpWinL + 1
if confluenceShort[perfpHorizon]
    perfpTotS := perfpTotS + 1
    if close < close[perfpHorizon]
        perfpWinS := perfpWinS + 1
perfpRateL = perfpTotL > 0 ? 100.0 * perfpWinL / perfpTotL : 0.0
perfpRateS = perfpTotS > 0 ? 100.0 * perfpWinS / perfpTotS : 0.0
var table perfpTbl = table.new(position.top_right, 3, 3, bgcolor=color.new(color.black, 82), border_width=1, border_color=color.new(color.gray, 80))
if perfpShow and barstate.islast
    table.cell(perfpTbl, 0, 0, "시그널 성과", text_size=size.tiny, text_color=color.new(color.white, 10), bgcolor=color.new(color.gray, 70))
    table.cell(perfpTbl, 1, 0, "적중률", text_size=size.tiny, text_color=color.new(color.white, 25), bgcolor=color.new(color.gray, 70))
    table.cell(perfpTbl, 2, 0, "표본", text_size=size.tiny, text_color=color.new(color.white, 25), bgcolor=color.new(color.gray, 70))
    table.cell(perfpTbl, 0, 1, "▲ LONG", text_size=size.tiny, text_color=color.new(color.teal, 0))
    table.cell(perfpTbl, 1, 1, str.tostring(perfpRateL, "#.0") + "%", text_size=size.tiny, text_color=color.new(color.teal, 0))
    table.cell(perfpTbl, 2, 1, str.tostring(perfpTotL), text_size=size.tiny, text_color=color.new(color.white, 35))
    table.cell(perfpTbl, 0, 2, "▼ SHORT", text_size=size.tiny, text_color=color.new(color.orange, 0))
    table.cell(perfpTbl, 1, 2, str.tostring(perfpRateS, "#.0") + "%", text_size=size.tiny, text_color=color.new(color.orange, 0))
    table.cell(perfpTbl, 2, 2, str.tostring(perfpTotS), text_size=size.tiny, text_color=color.new(color.white, 35))


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 11 - 플랫폼 상태 대시보드
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

dashPosIn = input.string("우하단", "패널 위치", options=["우상단", "우중단", "우하단", "좌상단", "좌하단"], group=grpVisual, tooltip="상태 패널이 표시될 차트 모서리 위치")
dashSizeIn = input.string("보통", "패널 글자 크기", options=["작게", "보통", "크게"], group=grpVisual, tooltip="상태 패널 텍스트 크기 — 화면 해상도에 맞게 조절하세요")
dashPos = dashPosIn == "우상단" ? position.top_right : dashPosIn == "우중단" ? position.middle_right : dashPosIn == "우하단" ? position.bottom_right : dashPosIn == "좌상단" ? position.top_left : position.bottom_left
dashTxtSz = dashSizeIn == "작게" ? size.tiny : dashSizeIn == "보통" ? size.small : size.normal
var table platDash = table.new(dashPos, 2, 13, border_width=1, bgcolor=color.new(color.black, 90))
if showPlatformDash and barstate.islast
    table.cell(platDash, 0, 0, "FIELD", text_size=dashTxtSz, bgcolor=color.new(color.gray, 75))
    table.cell(platDash, 1, 0, "VALUE", text_size=dashTxtSz, bgcolor=color.new(color.gray, 75))
    table.cell(platDash, 0, 1, "Structure", text_size=dashTxtSz, bgcolor=color.new(color.black, 82))
    table.cell(platDash, 1, 1, msBias, text_size=dashTxtSz, bgcolor=color.new(color.black, 70))
    table.cell(platDash, 0, 2, "Session", text_size=dashTxtSz, bgcolor=color.new(color.black, 82))
    table.cell(platDash, 1, 2, sessionName, text_size=dashTxtSz, bgcolor=color.new(color.black, 70))
    table.cell(platDash, 0, 3, "Signal", text_size=dashTxtSz, bgcolor=color.new(color.black, 82))
    sigTxt = longSignal ? "LONG" : shortSignal ? "SHORT" : "—"
    table.cell(platDash, 1, 3, sigTxt, text_size=dashTxtSz, bgcolor=color.new(color.black, 70))
    table.cell(platDash, 0, 4, "Score", text_size=dashTxtSz, bgcolor=color.new(color.black, 82))
    table.cell(platDash, 1, 4, str.tostring(score, "#.#"), text_size=dashTxtSz, bgcolor=color.new(color.black, 70))
    table.cell(platDash, 0, 5, "Conf", text_size=dashTxtSz, bgcolor=color.new(color.black, 82))
    table.cell(platDash, 1, 5, confluenceLong ? "LONG" : confluenceShort ? "SHORT" : "—", text_size=dashTxtSz, bgcolor=color.new(color.black, 70))
    table.cell(platDash, 0, 6, "FVG", text_size=dashTxtSz, bgcolor=color.new(color.black, 82))
    table.cell(platDash, 1, 6, bullFvg ? "BULL" : bearFvg ? "BEAR" : "—", text_size=dashTxtSz, bgcolor=color.new(color.black, 70))
    table.cell(platDash, 0, 7, "Boxes", text_size=dashTxtSz, bgcolor=color.new(color.black, 82))
    table.cell(platDash, 1, 7, str.tostring(array.size(boxPool)), text_size=dashTxtSz, bgcolor=color.new(color.black, 70))
    if useMtfDash
        table.cell(platDash, 0, 8, "MTF", text_size=size.tiny, bgcolor=color.new(color.gray, 75))
        table.cell(platDash, 1, 8, "BIAS", text_size=size.tiny, bgcolor=color.new(color.gray, 75))
        table.cell(platDash, 0, 9, "15", text_size=size.tiny, bgcolor=color.new(color.black, 82))
        mtfBias0 = mtf0 ? "BULL" : "BEAR"
        table.cell(platDash, 1, 9, mtfBias0, text_size=size.tiny, bgcolor=color.new(color.black, 70))
        table.cell(platDash, 0, 10, "60", text_size=size.tiny, bgcolor=color.new(color.black, 82))
        mtfBias1 = mtf1 ? "BULL" : "BEAR"
        table.cell(platDash, 1, 10, mtfBias1, text_size=size.tiny, bgcolor=color.new(color.black, 70))
        table.cell(platDash, 0, 11, "240", text_size=size.tiny, bgcolor=color.new(color.black, 82))
        mtfBias2 = mtf2 ? "BULL" : "BEAR"
        table.cell(platDash, 1, 11, mtfBias2, text_size=size.tiny, bgcolor=color.new(color.black, 70))
        table.cell(platDash, 0, 12, "D", text_size=size.tiny, bgcolor=color.new(color.black, 82))
        mtfBias3 = mtf3 ? "BULL" : "BEAR"
        table.cell(platDash, 1, 12, mtfBias3, text_size=size.tiny, bgcolor=color.new(color.black, 70))


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// ui_signal_legend — 범례 패널
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

lgdShow = input.bool(true, "범례 패널", group=grpVisual, tooltip="차트 마커와 색상의 의미를 설명하는 범례 패널을 표시합니다")
var table lgdTbl = table.new(position.bottom_left, 1, 10, bgcolor=color.new(color.black, 85), border_width=1, border_color=color.new(color.gray, 80))
if lgdShow and barstate.islast
    table.cell(lgdTbl, 0, 0, "범례", text_size=size.tiny, text_color=color.new(color.white, 10), bgcolor=color.new(color.gray, 70))
    table.cell(lgdTbl, 0, 1, "BOS/CHoCH — 구조 돌파·추세 전환", text_size=size.tiny, text_color=color.new(color.white, 25), text_halign=text.align_left)
    table.cell(lgdTbl, 0, 2, "FVG 박스 — 가격 불균형 영역", text_size=size.tiny, text_color=color.new(color.white, 25), text_halign=text.align_left)
    table.cell(lgdTbl, 0, 3, "OB 박스 — 오더 블록 (기관 관심 구간)", text_size=size.tiny, text_color=color.new(color.white, 25), text_halign=text.align_left)
    table.cell(lgdTbl, 0, 4, "EQH/EQL — 동일 고저 유동성 라인", text_size=size.tiny, text_color=color.new(color.white, 25), text_halign=text.align_left)
    table.cell(lgdTbl, 0, 5, "◆ — 다중 조건 합류 시그널", text_size=size.tiny, text_color=color.new(color.white, 25), text_halign=text.align_left)
    table.cell(lgdTbl, 0, 6, "▲▼ — 오프닝 레인지 돌파", text_size=size.tiny, text_color=color.new(color.white, 25), text_halign=text.align_left)
    table.cell(lgdTbl, 0, 7, "▲▼(소형) — 변동성 스퀴즈 해제", text_size=size.tiny, text_color=color.new(color.white, 25), text_halign=text.align_left)
    table.cell(lgdTbl, 0, 8, "◇ — OBV 다이버전스", text_size=size.tiny, text_color=color.new(color.white, 25), text_halign=text.align_left)
    table.cell(lgdTbl, 0, 9, "청록 = 강세 · 주황 = 약세 · 회색 = 중립", text_size=size.tiny, text_color=color.new(color.white, 25), text_halign=text.align_left)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// ui_top_info_bar — 상단 정보 바
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

tibShow = input.bool(true, "상단 정보 바", group=grpVisual, tooltip="심볼·시간대·추세 방향·변동성(ATR%)을 요약한 상단 미니 바를 표시합니다")
tibEma = ta.ema(close, 50)
tibAtrPct = ta.atr(14) / math.max(close, syminfo.mintick) * 100
tibBull = close > tibEma
var table tibTbl = table.new(position.top_center, 4, 1, bgcolor=color.new(color.black, 80), border_width=1, border_color=color.new(color.gray, 82))
if tibShow and barstate.islast
    table.cell(tibTbl, 0, 0, syminfo.ticker, text_size=size.tiny, text_color=color.new(color.white, 10))
    table.cell(tibTbl, 1, 0, timeframe.period, text_size=size.tiny, text_color=color.new(color.white, 30))
    table.cell(tibTbl, 2, 0, tibBull ? "▲ 상승 추세" : "▼ 하락 추세", text_size=size.tiny, text_color=tibBull ? color.new(color.teal, 0) : color.new(color.orange, 0))
    table.cell(tibTbl, 3, 0, "ATR " + str.tostring(tibAtrPct, "#.##") + "%", text_size=size.tiny, text_color=color.new(color.gray, 20))


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// ui_watermark
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

if barstate.islast
    label.new(bar_index, high, "MANTIS", style=label.style_label_down, color=color.new(color.gray, 100), textcolor=color.gray, size=size.tiny)
// [PLATFORM_END_DASHBOARD]

