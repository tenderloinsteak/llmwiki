// [PLATFORM_START_CORE]
// [AI_START_LOGIC]
longSignal = cvdBull and deltaBull and rvolVal >= minRvol
shortSignal = cvdBear and deltaBear and rvolVal >= minRvol
plot(rvolVal, "RVOL", color=color.blue, display=display.pane)
// [AI_END_LOGIC]
// [PLATFORM_END_CORE]

// [PLATFORM_START_CONFLUENCE]

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// sig_notifier
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

alert(longSignal ? "Long signal" : na, alert.freq_once_per_bar_close)
alert(shortSignal ? "Short signal" : na, alert.freq_once_per_bar_close)
// [PLATFORM_END_CONFLUENCE]

// [PLATFORM_START_SCORE]

// [PLATFORM_END_SCORE]

