// [PLATFORM_START_ALERTS]

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 09 - 알림 허브
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

alertcondition(useAlertHub and bosUp, title="Order_Flow_SKU05 BOS Up", message="Order_Flow_SKU05 BOS Bullish on {ticker}")
alertcondition(useAlertHub and bosDn, title="Order_Flow_SKU05 BOS Dn", message="Order_Flow_SKU05 BOS Bearish on {ticker}")
alertcondition(useAlertHub and chochUp, title="Order_Flow_SKU05 CHoCH Up", message="Order_Flow_SKU05 CHoCH Bullish")
alertcondition(useAlertHub and chochDn, title="Order_Flow_SKU05 CHoCH Dn", message="Order_Flow_SKU05 CHoCH Bearish")
alertcondition(useAlertHub and liqSweepHigh, title="Order_Flow_SKU05 Liq Grab High", message="Order_Flow_SKU05 Liquidity sweep high")
alertcondition(useAlertHub and liqSweepLow, title="Order_Flow_SKU05 Liq Grab Low", message="Order_Flow_SKU05 Liquidity sweep low")
alertcondition(useAlertHub and longSignal, title="Order_Flow_SKU05 Long Signal", message="Order_Flow_SKU05 LONG signal")
alertcondition(useAlertHub and shortSignal, title="Order_Flow_SKU05 Short Signal", message="Order_Flow_SKU05 SHORT signal")
if useAlertHub and barstate.isconfirmed and (longSignal or shortSignal)
    alert("Order_Flow_SKU05 " + (longSignal ? "LONG" : "SHORT") + " | " + syminfo.ticker + " @ " + str.tostring(close, format.mintick), alert.freq_once_per_bar_close)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 알림
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

alertcondition(longSignal, title="Order_Flow_SKU05 Long Signal", message="Order_Flow_SKU05 long signal on {ticker}")
alertcondition(shortSignal, title="Order_Flow_SKU05 Short Signal", message="Order_Flow_SKU05 short signal on {ticker}")
// [PLATFORM_END_ALERTS]

// [PLATFORM_START_DASHBOARD]

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 11 - 플랫폼 상태 대시보드
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

dashPosIn = input.string("우중단", "패널 위치", options=["우상단", "우중단", "우하단", "좌상단", "좌하단"], group=grpVisual, tooltip="상태 패널이 표시될 차트 모서리 위치")
dashSizeIn = input.string("보통", "패널 글자 크기", options=["작게", "보통", "크게"], group=grpVisual, tooltip="상태 패널 텍스트 크기 — 화면 해상도에 맞게 조절하세요")
dashPos = dashPosIn == "우상단" ? position.top_right : dashPosIn == "우중단" ? position.middle_right : dashPosIn == "우하단" ? position.bottom_right : dashPosIn == "좌상단" ? position.top_left : position.bottom_left
dashTxtSz = dashSizeIn == "작게" ? size.tiny : dashSizeIn == "보통" ? size.small : size.normal
var table platDash = table.new(dashPos, 2, 5, border_width=1, bgcolor=color.new(color.black, 90))
if showPlatformDash and barstate.islast
    table.cell(platDash, 0, 0, "FIELD", text_size=dashTxtSz, bgcolor=color.new(color.gray, 75))
    table.cell(platDash, 1, 0, "VALUE", text_size=dashTxtSz, bgcolor=color.new(color.gray, 75))
    table.cell(platDash, 0, 1, "Structure", text_size=dashTxtSz, bgcolor=color.new(color.black, 82))
    table.cell(platDash, 1, 1, msBias, text_size=dashTxtSz, bgcolor=color.new(color.black, 70))
    table.cell(platDash, 0, 2, "Session", text_size=dashTxtSz, bgcolor=color.new(color.black, 82))
    table.cell(platDash, 1, 2, sessionName, text_size=dashTxtSz, bgcolor=color.new(color.black, 70))
    table.cell(platDash, 0, 3, "Signal", text_size=dashTxtSz, bgcolor=color.new(color.black, 82))
    sigTxt = longSignal ? "LONG" : shortSignal ? "SHORT" : "—"
    table.cell(platDash, 1, 3, sigTxt, text_size=dashTxtSz, bgcolor=color.new(color.black, 70))
    table.cell(platDash, 0, 4, "Boxes", text_size=dashTxtSz, bgcolor=color.new(color.black, 82))
    table.cell(platDash, 1, 4, str.tostring(array.size(boxPool)), text_size=dashTxtSz, bgcolor=color.new(color.black, 70))
// [PLATFORM_END_DASHBOARD]

